{"sections":{"main":{"type":"main-page","disabled":true,"settings":{}},"40b0757c-594a-4cba-bf71-3fc7daeb75f1":{"type":"slideshow","blocks":{"template--16816233185537__40b0757c-594a-4cba-bf71-3fc7daeb75f1-image-1":{"type":"image","settings":{"top_subheading":"","title":"","title_size":80,"subheading":"","link":"","link_text":"","link_2":"","link_text_2":"","color_accent":"rgba(0,0,0,0)","text_align":"vertical-center horizontal-center","image":"shopify:\/\/shop_images\/MDM_nov18_005-01-01.png","parallax_direction":"top","overlay_opacity":0}}},"block_order":["template--16816233185537__40b0757c-594a-4cba-bf71-3fc7daeb75f1-image-1"],"settings":{"section_height":"550px","mobile_height":"auto","parallax":false,"style":"arrows","autoplay":true,"autoplay_speed":5,"lazyload_images":false}},"73614dc2-5d13-4321-b783-4842840f9415":{"type":"rich-text","blocks":{"template--16816233185537__73614dc2-5d13-4321-b783-4842840f9415-heading-1":{"type":"heading","settings":{"title":"WHAT IS KLARNA?"}},"template--16816233185537__73614dc2-5d13-4321-b783-4842840f9415-text-1":{"type":"text","settings":{"enlarge_text":true,"text":"<p>MARCO DAL MASO has partnered with Klarna to offer our customers flexible finance options. When you choose Klarna at checkout, you’ll get the option to shop now and pay later for your purchase.<\/p>"}}},"block_order":["template--16816233185537__73614dc2-5d13-4321-b783-4842840f9415-heading-1","template--16816233185537__73614dc2-5d13-4321-b783-4842840f9415-text-1"],"settings":{"align_text":"center","narrow_column":true,"divider":false}},"89fc3f54-2081-4979-9e93-64e86cde7e85":{"type":"advanced-content","blocks":{"123da9bd-d9ba-4bba-a299-19a3dbb390f9":{"type":"liquid","settings":{"code":"<div class=\"text-center\"><h2>PAY IN 30 DAYS<\/h2><p>Purchase today and enjoy what you’ve ordered right away.<br><br>\n\nPay up to 30 days after shipping.<br><br>\n\nNo interest.<br><br>\n\nNo fees.<\/p><\/div>","width":"50%","alignment":"center"}},"template--16816233185537__89fc3f54-2081-4979-9e93-64e86cde7e85-liquid-1":{"type":"liquid","settings":{"code":"<div class=\"text-center\"><h2>PAY IN 3 INSTALMENTS<\/h2><p>Split your purchase into three equal payments and spread the cost over time. Enter your details when prompted and make automatic payments every 30 days. Your first instalment will be collected when your order is confirmed by marcodalmaso.com and instalments 2 and 3 are scheduled 30 and 60 days later, respectively.<br><br>\n\nNo interest or fees.<\/p><\/div>","width":"50%","alignment":"center"}}},"block_order":["123da9bd-d9ba-4bba-a299-19a3dbb390f9","template--16816233185537__89fc3f54-2081-4979-9e93-64e86cde7e85-liquid-1"],"settings":{"full_width":false,"space_around":true,"lazyload_images":true}},"53312c22-e933-4f24-a85f-5087806ba066":{"type":"text-columns","blocks":{"template--16816233185537__53312c22-e933-4f24-a85f-5087806ba066-text_block-1":{"type":"text_block","settings":{"enable_image":true,"image":"shopify:\/\/shop_images\/klarna123-01.png","image_mask":"none","image_width":350,"title":"ADD ITEM(S)","text":"<p>Add item(s) to your cart and proceed to the checkout.<\/p>","button_label":"","button_link":""}},"template--16816233185537__53312c22-e933-4f24-a85f-5087806ba066-text_block-2":{"type":"text_block","settings":{"enable_image":true,"image":"shopify:\/\/shop_images\/klarna123-02.png","image_mask":"none","image_width":350,"title":"SELECT KLARNA","text":"<p>Select Klarna at the checkout to pay as you like for your purchase.<\/p>","button_label":"","button_link":""}},"template--16816233185537__53312c22-e933-4f24-a85f-5087806ba066-text_block-3":{"type":"text_block","settings":{"enable_image":true,"image":"shopify:\/\/shop_images\/klarna123-03.png","image_mask":"none","image_width":350,"title":"MANAGE YOUR ORDERS","text":"<p>Manage your orders and payments in the Klarna app<\/p>","button_label":"","button_link":""}}},"block_order":["template--16816233185537__53312c22-e933-4f24-a85f-5087806ba066-text_block-1","template--16816233185537__53312c22-e933-4f24-a85f-5087806ba066-text_block-2","template--16816233185537__53312c22-e933-4f24-a85f-5087806ba066-text_block-3"],"settings":{"title":"HOW KLARNA WORKS","text":"","align_text":"center","divider":false}},"bb1898d3-c815-4aca-8dee-1f3b4b816ec5":{"type":"rich-text","blocks":{"template--16816233185537__bb1898d3-c815-4aca-8dee-1f3b4b816ec5-heading-1":{"type":"heading","settings":{"title":"ON CHECKOUT COMPLETION"}},"template--16816233185537__bb1898d3-c815-4aca-8dee-1f3b4b816ec5-text-1":{"type":"text","settings":{"enlarge_text":true,"text":"<p>We will process and ship your order within our standard processing times. Klarna has strong anti-fraud controls in place to protect its customers and prevent fraud.<\/p><p><a href=\"http:\/\/www.klarna.com\/uk\/smoooth\/\" target=\"_blank\" title=\"http:\/\/www.klarna.com\/uk\/smoooth\/\">Learn more about Klarna<\/a><\/p>"}}},"block_order":["template--16816233185537__bb1898d3-c815-4aca-8dee-1f3b4b816ec5-heading-1","template--16816233185537__bb1898d3-c815-4aca-8dee-1f3b4b816ec5-text-1"],"settings":{"align_text":"center","narrow_column":true,"divider":false}}},"order":["main","40b0757c-594a-4cba-bf71-3fc7daeb75f1","73614dc2-5d13-4321-b783-4842840f9415","89fc3f54-2081-4979-9e93-64e86cde7e85","53312c22-e933-4f24-a85f-5087806ba066","bb1898d3-c815-4aca-8dee-1f3b4b816ec5"]}