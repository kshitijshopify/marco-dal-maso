nly the finest materials are selected to make each piece as well as ensuring each stage of sourcing and production is conflict free.<\/p>","html":"","button_label":"","button_link":"","button_labels":"","button_links":"","button_style":"primary","align_text":"left","image_width":"50","layout":"left","body_bg":"#e7e7e7","divider":false,"top_padding":true,"bottom_padding":true,"lazyload_images":true}},"slideshow_old_AHjKBw":{"type":"slideshow-old","blocks":{"image_wkRQhn":{"type":"image","settings":{"top_subheading":"\"My inspirations are compounded in each facet of what we do. Italian craftsmanship, sustainability and a daring sense of creativity is at the heart of what we are creating.”","title":"","title_size":51,"subheading":"-Marco Dal Maso","text_color":"#ffffff","link":"","link_text":"","link_2":"","link_text_2":"","color_accent":"rgba(0,0,0,0)","text_align":"vertical-center horizontal-center","text_align_mobiles":"mobvertical-center mobhorizontal-center","image":"shopify:\/\/shop_images\/MDM_apr18_0080_398efd6b-c3e3-4477-a159-e05e472b960b.jpg","video":"","video_mobile":"","object-position":"center","parallax_direction":"top","overlay_opacity":0}}},"block_order":["image_wkRQhn"],"name":"t:sections.slideshow.presets.hero_optional_slideshow.name","settings":{"section_height":"650px","mobile_height":"auto","first_section":false,"parallax":false,"style":"bars","autoplay":true,"autoplay_speed":5,"lazyload_images":false}},"d530a7f6-0278-4a8d-9b64-02b6bec73df1":{"type":"rich-text","blocks":{"template--16791904059649__d530a7f6-0278-4a8d-9b64-02b6bec73df1-heading-1":{"type":"heading","settings":{"title":"EXPLORE THE COLLECTIONS"}},"f8595bc7-f7f1-4824-88c4-9dcc93e84e34":{"type":"button","settings":{"link":"shopify:\/\/collections\/all","link_text":"VIEW PRODUCTS","link_2":"","link_text_2":""}}},"block_order":["template--16791904059649__d530a7f6-0278-4a8d-9b64-02b6bec73df1-heading-1","f8595bc7-f7f1-4824-88c4-9dcc93e84e34"],"custom_css":[".section--divider {padding-bottom: