{%- liquid
  assign current_filter_size = 0

  for filter in collection.filters
    assign current_filter_size = current_filter_size | plus: filter.active_values.size
  endfor
-%}

{%- capture shoplookcontent -%}
{% if section.settings.image != blank %}
  {% for meta in shop.metaobjects.collection_shop_look.values %}
    {% assign related_products = meta.shop_look_products.value %}
    {% if meta.collection_title == collection.title %}
      {% render 'variable-products-grid-item-main-collection', related_products: related_products, 2: 2, settings: settings, '39vw': '39vw', paginate_by: paginate_by %}
      {% for prod in related_products %}
        {%- render 'product-grid-item',
                  product: prod, per_row: 2, quick_shop_enable: settings.quick_shop_enable, fallback: '39vw', -%}
      {% endfor %}
      {% endif %}
  {% endfor %}
{% endif %}
{%- endcapture -%}

{% if collection.image %}
    <div class="collection-image">
        <img src="{{ collection.image | img_url: 'large' }}" 
             alt="{{ collection.image.alt | default: collection.title | escape }}" 
             loading="lazy">
    </div>
{% endif %}


<div
  class="collection-content"
  data-section-id="{{ section.id }}"
  data-section-type="collection-grid"
>
  <div class="page-width">
        {% if section.settings.showsubcolls__belowheader %}
        {%- for block in section.blocks -%}
            <div {{ block.shopify_attributes }}>
              {%- case block.type -%}
              {%- when 'subcollections' -%}
                {% if collection.title == 'Diamonds' %}
                  {%- render 'diamonds-subcollections', per_row: block.settings.subcollections_per_row,block: block -%}
                {% else %}
                  {%- render 'subcollections', per_row: block.settings.subcollections_per_row,block: block -%}
                {% endif %}
              {%- endcase -%}
            </div>
        {%- endfor -%}
        {% endif %}
  </div>
  <div id="CollectionAjaxContent">
    <div class="page-width">
      <div class="grid">
        <div class="grid__item medium-up--one-fifth grid__item--sidebar">
          {%- render 'collection-grid-filters',
            collection: collection,
            enable_sidebar: section.settings.enable_sidebar,
            filter_style: section.settings.filter_style,
            collapsed: section.settings.collapsed,
            enable_color_swatches: section.settings.enable_color_swatches
          -%}
        </div>
        <div class="grid__item medium-up--four-fifths grid__item--content">
          {%- liquid
            for block in section.blocks
              case block.type
              when 'product_grid'
                assign paginate_by = block.settings.per_row | times: block.settings.rows_per_page
              endcase
            endfor
          -%}
          {%- paginate collection.products by paginate_by -%}
          {%- for block in section.blocks -%}
            <div {{ block.shopify_attributes }} {%- if block.type == 'product-grid' -%}data-scroll-to{%- endif -%}>
              {%- case block.type -%}
              {%- when 'collection_description' -%}
                {%- if collection.description != blank and current_filter_size == 0 -%}
                  <div class="rte collection__description">
                    {{ collection.description }}
                  </div>
                {%- endif -%}
              {%- when 'subcollections' -%}
                {% unless section.settings.showsubcolls__belowheader %}
                {%- if paginate.current_page == 1 and current_filter_size == 0 -%}
                  {%- render 'subcollections', per_row: block.settings.subcollections_per_row, block: block -%}
                {%- endif -%}
                {% endunless %}
              {%- when 'product_grid' -%}
                <div data-scroll-to>
                  {% render 'collection-grid',
                    collection: collection,
                    section: section,
                    items: collection.products,
                    enable_sidebar: section.settings.enable_sidebar,
                    filter_style: section.settings.filter_style,
                    enable_sort: section.settings.enable_sort,
                    enable_collection_count: block.settings.enable_collection_count,
                    per_row: block.settings.per_row,
                    mobile_flush_grid: block.settings.mobile_flush_grid,
                    quick_shop_enable: settings.quick_shop_enable,
                    lookimage: section.settings.image
                  %}
                  {%- if paginate.pages > 1 -%}
                    {%- render 'pagination', paginate: paginate -%}
                  {%- endif -%}
                </div>
              {%- endcase -%}
            </div>
          {%- endfor -%}

          {%- endpaginate -%}
        </div>
      </div>
    </div>
  </div>
</div>

<div class="popcontent_overlay"></div>
<div class="popupcontent">
  <div class="close_block"><div class="close">x</div></div>
  <div class="popupprods">
  {{ shoplookcontent }}
  </div>
</div>

<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.4/jquery.min.js"></script>
<script>
  $('.collmetafieldbanner').click(function(){
    $('.popupcontent').toggleClass('active');
    $('.popcontent_overlay').toggleClass('active');
    $('.popupcontent').slideToggle
    $('body').toggleClass('ov-hid');
  });
  $('.popcontent_overlay , .close').click(function(){
    $('.popupcontent').toggleClass('active');
    $('.popcontent_overlay').toggleClass('active');
    $('body').toggleClass('ov-hid');
  });
</script>
  <style>
  .popupcontent, .popcontent_overlay{visibility: hidden; opacity: 0;transition:all .5s ease-in-out;right:-100vw;}
  .popupcontent, .popcontent_overlay { position: fixed; top: 0px; height: 100vh; overflow: auto; width: 50vw; background: #fff; z-index: -1; display: block; }
  .popupcontent.active,.popcontent_overlay.active { visibility: visible; opacity: 1; right: 0px; z-index: 9999; }
  .popcontent_overlay.active{left: 0;}
  .popcontent_overlay{left:0px;height:100vh;overflow:auto;width:50vw;background:rgba(0,0,0,0.5);z-index:-1;}
   body.ov-hid{overflow:hidden;}
   .close_block{ display: block;text-align: right;}
  .popupcontent .close {font-size: 36px;padding: 0px 20px;cursor: pointer;}
  .product-callout__button{cursor:pointer;}
    @media screen and (max-width:800px){
        body .popupcontent.active{width:100vw;} 
        body .popcontent_overlay.active{width:0px;}
        .popupcontent .grid__item{max-width:50%;}
    }
  </style>

{%- if section.settings.enable_sidebar == false or section.settings.filter_style == 'drawer' or collection.filters.size == 0 -%}
{% comment %}
  Override grid styles if sidebar is disabled
{% endcomment %}
{% style %}
  .collection-content .grid__item--sidebar { width: 0; padding:0; }
  .collection-content .grid__item--content { width: 100%; }
  .grid__item--sidebar { position: static; overflow: hidden; }
{% endstyle %}
{%- endif -%}

<script type="application/ld+json">
{
  "@context": "http://schema.org",
  "@type": "CollectionPage",
  {% if collection.description != blank %}
    "description": {{ collection.description | strip_html | json }},
  {% endif %}
  {% if page_image %}
    {% assign image_size = page_image.width | append: 'x' %}
    "image": {
      "@type": "ImageObject",
      "height": {{ page_image.height | json }},
      "url": {{ page_image | img_url: image_size | prepend: "https:" | json }},
      "width": {{ page_image.width | json }}
    },
  {% endif %}
  "name": {{ collection.title | json }}
}
</script>

