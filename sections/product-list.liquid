{%- assign per_row = section.settings.per_row -%}
{%- assign product_limit = per_row | times: section.settings.rows -%}
{%- assign collection = collections[section.settings.home_featured_products] -%}

{%- if section.settings.divider -%}<div class="section--divider">{%- endif -%}

<div
  id="CollectionSection-{{ section.id }}"
  data-section-id="{{ section.id }}"
  data-section-type="collection-grid"
  data-context="featured-collection">
  {%- if section.settings.title != blank or section.settings.view_all -%}
    <div class="page-width">
      <div class="section-header{% if section.settings.view_all %}{% unless settings.type_headers_align_text %} section-header--with-link{% endunless %}{% endif %}">
        <h2 class="section-header__title">
          {{ section.settings.title }}
        </h2>
        
        {%- if section.settings.text != blank -%}
          <div class="rte">
            {%- if section.settings.enlarge_text %}<div class="enlarge-text">{% endif -%}
              {{ section.settings.text }}
            {%- if section.settings.enlarge_text %}</div>{% endif -%}
          </div>
        {%- endif -%}
        
        {%- if section.settings.view_all and section.settings.rows == 1 -%}
          <a href="{{ collections[section.settings.home_featured_products].url }}" class="btn btn--secondary btn--small section-header__link">{{ 'collections.general.all_of_collection' | t }}</a>
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}

  <div class="page-width {% if section.settings.slider_flow %}slider_flow {% endif %}  {% unless section.settings.carousel %}{% if section.settings.mobile_scrollable %}  page-width--flush-small{% endif %}{% endunless %}">
    {% if template == 'page.mens' %}<div class="featured_collection_flex">
      <div class="video_grid">
        <video class="" width="100%" height="100%" muted="" autoplay="" loop="" playinline="">
          <source src="https://cdn.shopify.com/videos/c/o/v/6d6c6b9286fe4658a0dc94a0cac33260.mp4" type="video/mp4">
        </video>
      </div>{% endif %}
    
    <div{% unless section.settings.carousel %}{% if section.settings.mobile_scrollable %} class="grid-overflow-wrapper"{% endif %}{% endunless %}>
      <div class="{% if section.settings.carousel %}p-carousel {% else %}grid grid--uniform{% endif %}"{% unless section.settings.carousel %}{% if section.settings.mobile_scrollable %} data-aos="overflow__animation"{% endif %}{% endunless %} data-perrow="{{ per_row }}">
        {%- liquid
          capture gridView
            render 'products_per_row', products_per_row: per_row, style: 'fractions'
          endcapture

          if section.settings.mobile_scrollable
            assign fallback = '39vw'
          else
            assign fallback = 'variable'
          endif
        -%}

    

          {%- for block in section.blocks -%}
            
{%- assign product = all_products[block.settings.home_featured_products] -%}
            {%- render 'product-grid-item',
              product: product,
              collection: collection,
              per_row: per_row,
              section: section, 
              quick_shop_enable: settings.quick_shop_enable,
              fallback: fallback,
            -%}
          {%- endfor -%}


      </div>
      
          {%- if section.settings.url != blank -%}
            <br/>
            <div class="grid">
              <div class="grid__item grid__item--view-all text-center">
                <a href="{{ section.settings.url }}" class="btn grid-product__see-all">
                  {{ section.settings.level }}
                </a>
              </div>
            </div>
          {%- endif -%}
    </div>
    {% if template == 'page.mens' %}</div>{% endif %}
  </div>
</div>

{%- if section.settings.divider -%}</div>{%- endif -%}
{% if section.settings.slider_flow %}
<style>
  
  .mobile_slider  .flex-grid__item{display:flex !important;}
@media only screen and (min-width:769px){
.page-width.slider_flow{
    padding: 0 0px 0px calc((100% - 1450px) / 2);
    max-width: 100%;width: 100%;}
}
 .mobile_slider  ul.slick-dots {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 7px;
    list-style: none;
    font-size: 0px;
    border-radius: 30px;
    margin: 15px 0px 0px;
    padding: 0px;
}
.mobile_slider   .slick-track {
    /* max-width: 100vw; */
}
  .mobile_slider ul.slick-dots li button {
    background: #000;
    padding: 2px;
    width: 6px;
    height: 6px;
    border-radius: 30px;
    font-size: 0px;
}
@media only screen and (max-width:768px){
  .header-item--logo{flex:0 1 120px;
        max-width: 120px;
        overflow: hidden;}
  .site-header .site-header__logo img{
    max-width: 100% !important;
    object-fit: contain;
  }
  .site-header__logo{max-width:100%;}
  .slick-slide {
    float: left;
    max-width: 100vw;
}
}
</style>
{% endif %}
{% schema %}
{
  "name": "PRODUCT LIST",
  "class": "index-section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "t:sections.featured-collection.settings.title.label",
      "default": "Featured collection"
    },
    {
          "type": "checkbox",
          "id": "enlarge_text",
          "label": "t:sections.rich-text.blocks.text.settings.enlarge_text.label",
          "default": true
        },
        {
          "id": "text",
          "type": "richtext",
          "label": "t:sections.rich-text.blocks.text.settings.text.label"
        },
    {
      "type": "range",
      "id": "per_row",
      "label": "t:sections.featured-collection.settings.per_row.label",
      "default": 4,
      "min": 1,
      "max": 5,
      "step": 1
    },
    {
      "type": "range",
      "id": "rows",
      "label": "t:sections.featured-collection.settings.rows.label",
      "default": 1,
      "min": 1,
      "max": 5,
      "step": 1
    },
    {
      "type": "checkbox",
      "id": "mobile_scrollable",
      "label": "t:sections.featured-collection.settings.mobile_scrollable.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "carousel",
      "label": "Enable carousel",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "slider_flow",
      "label": "Enable slider overflow",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "view_all",
      "label": "t:sections.featured-collection.settings.view_all.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "divider",
      "label": "t:sections.featured-collection.settings.divider.label",
      "default": false
    },
    {
      "type": "url",
      "id": "url",
      "label": "Link"
    },
    {
      "type": "text",
      "id": "level",
      "label": "Link level"
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
            {
              "type": "product",
              "id": "home_featured_products",
              "label": "Select Product"
            }
      ]
    }
  ],
  "presets": [
    {
      "name": "PRODUCT LIST",
    }
  ],
  "disabled_on": {
    "groups": ["footer", "header", "custom.popups"]
  }
}
{% endschema %}
