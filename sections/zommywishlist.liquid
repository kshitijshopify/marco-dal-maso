<style>
  div#ZoomyWishlistPage {
    padding-left: 12px;
}
  .zopencartlink {
    letter-spacing: 1px;
  }
  @media screen and (min-width: 768px) {
  .ZoomyWishlistPageGrid {
    width: 23%!important;
    border: none!important;
    padding: 0!important;
}
    #ZoomyWishlistPage li img {
    min-height: 325px;
    max-height: 325px;
}
  }
  @media screen and (max-width: 767px) {
    #ZoomyWishlistPage .ZoomyWishlistPageGrid {
        width: 50%;
        margin: 10px 0;
    }
}
</style><div class="page-width page-content">
  {%- render 'breadcrumbs' -%}
  <header class="section-header">
    <h1 class="section-header__title">{{ page.title }}</h1>
  </header>

  <div class="rte rte--nomargin">
    {{ page.content }}
    <div id='ZoomyWishlistPage'></div><script src='https://zooomyapps.com/wishlist/v2/ListWishlist.js' data-shop-id='{{shop.permanent_domain}}' data-customer-id='{{customer.id}}' data-customer-email='{{customer.email}}'  ></script>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.main-page.name",
  "tag": "section"
}
{% endschema %}