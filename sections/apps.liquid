{%- if section.settings.space_around -%}
  <div class="index-section">
{%- endif -%}
{%- liquid
  assign image_width = section.settings.image_width
  assign overlap_images = true
  if section.settings.image == blank or section.settings.image2 == blank
    assign overlap_images = false
  endif

  if section.settings.image == blank 
    assign placeholder_images = true
  endif
-%}
{%- unless section.settings.full_width -%}
  <div class="page-width custom__appsection">
{%- elsif section.settings.image != blank -%}
  <div class="full-width _fixedimage_sliding_prods">
{%- endunless -%}
    
{%- capture image_layout -%}
<div class="feature-row__item feature-row__images {% if placeholder_images %}feature-row__item--placeholder-images{% endif %}" data-aos>
  {%- if section.settings.image != blank -%}
    {{ section.settings.image | img_url: "master" | img_tag }}
  {%- endif -%}
  {%- if section.settings.image == blank -%}
    <div class="placeholder-image-wrap">
      <div class="image-wrap">
        {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
      </div>
    </div>
  {%- endif -%}
</div>
{%- endcapture -%}

{%- if section.settings.image != blank -%}
  <style>
    .full-width._fixedimage_sliding_prods .feature-row .feature-row__item.feature-row__images {
    height: 90vh;
    width: auto;
    overflow: hidden;
    position: sticky;
    top: 55px;
    display: flex;position: -webkit-sticky;
    align-self: flex-start;
}
.full-width._fixedimage_sliding_prods .feature-row {
    align-items: flex-start;
    margin: 0;
}
    .full-width._fixedimage_sliding_prods .feature-row .feature-row__item.feature-row__images img {
    height: 100%;
    object-fit: cover;
}
  </style>
<div class="feature-row">
    {%- if section.settings.layout == 'left' -%}
        {{ image_layout }}
      {%- endif -%}

      <div class="feature-row__item feature-row__prods feature-row__text--{{ section.settings.layout }} text-{{ section.settings.align_text }}" data-aos>
{%- endif -%}
        {%- for block in section.blocks -%}
          {% render block %}
        {%- endfor -%}
{%- if section.settings.image != blank -%}  
      </div>

      {%- if section.settings.layout == 'right' -%}
        {{ image_layout }}
      {%- endif -%}
    </div>
{%- endif -%}

{%- unless section.settings.full_width -%}
  </div>
{%- elsif section.settings.image != blank -%}
  </div>
{%- endunless -%}

{%- if section.settings.space_around -%}
  </div>
{%- endif -%}

{% schema %}
{
  "name": "t:sections.apps.name",
  "tag": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "t:sections.apps.settings.full_width.label",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "space_around",
      "label": "t:sections.apps.settings.space_around.label",
      "default": true
    },
    {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.text-and-image.settings.image.label"
    },    
    {
      "type": "select",
      "id": "image_width",
      "label": "t:common.image_size.label",
      "default": "50",
      "options": [
        {
          "value": "33",
          "label": "t:common.image_size.options.small.label"
        },
        {
          "value": "50",
          "label": "t:common.image_size.options.medium.label"
        },
        {
          "value": "66",
          "label": "t:common.image_size.options.large.label"
        }
      ]
    },
    {
          "type": "select",
          "id": "layout",
          "label": "t:sections.text-and-image.settings.layout.label",
          "default": "right",
          "options": [
            {
              "value": "left",
              "label": "t:sections.text-and-image.settings.layout.options.left.label"
            },
            {
              "value": "right",
              "label": "t:sections.text-and-image.settings.layout.options.right.label"
            }
          ]
    }
  ],
  "blocks": [
    {
      "type": "@app"
    }
  ],
  "presets": [
    {
      "name": "t:sections.apps.presets.apps.name"
    }
  ]
}
{% endschema %}
