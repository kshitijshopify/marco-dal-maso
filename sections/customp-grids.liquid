{%- if section.settings.background_type == 'boxed' -%}
  {%- assign is_boxed = true -%}
{%- else -%}
  {%- assign is_boxed = false -%}
{%- endif -%}

{%- if section.settings.background != settings.background and section.settings.background != 'rgba(0,0,0,0)' -%}
  {%- assign blends_with_background = false -%}
{%- else -%}
  {%- assign blends_with_background = true -%}
{%- endif -%}

<style>
  #shopify-section-{{ section.id }} {
    {%- if section.settings.background == 'rgba(0,0,0,0)' -%}
      {%- assign section_background = settings.background -%}
    {%- else -%}
      {%- assign section_background = section.settings.background -%}
    {%- endif -%}

    {%- if section.settings.text_color == 'rgba(0,0,0,0)' -%}
      {%- assign heading_color = settings.heading_color -%}
      {%- assign text_color = settings.text_color -%}
    {%- else -%}
      {%- assign heading_color = section.settings.text_color -%}
      {%- assign text_color = section.settings.text_color -%}
    {%- endif -%}

    --heading-color: {{ heading_color.red }}, {{ heading_color.green }}, {{ heading_color.blue }};
    --text-color: {{ text_color.red }}, {{ text_color.green }}, {{ text_color.blue }};

    --section-background: {{ section_background.red }}, {{ section_background.green }}, {{ section_background.blue }};
  }
</style>

<section id="{{ section.settings.customid }}" class="image_with_video section {% unless blends_with_background or is_boxed %}section--flush{% endunless %}">
  <div {% if is_boxed %}class="page-width"{% endif %}>
    <div class="section__color-wrapper {% if is_boxed %}section__color-wrapper--boxed{% endif %}">
      <div class="{% unless is_boxed %}container{% endunless %} {% unless blends_with_background %}vertical-breather{% endunless %}">
        {%- if section.settings.subheading != blank or section.settings.title != blank -%}
          <header class="section__header text-container">
            {%- if section.settings.subheading != blank -%}
              <h2 class="heading heading--small">{{ section.settings.subheading | escape }}</h2>
            {%- endif -%}

            {%- if section.settings.title != blank -%}
              <h3 class="heading h2">{{ section.settings.title | escape }}</h3>
            {%- endif -%}
          </header>
        {%- endif -%}

        {%- if section.settings.liquid != blank -%}
          <div class="liquid">
            {{- section.settings.liquid -}}
          </div>
        {%- endif -%}
        <div class="grid">
          {%- assign row_width = 0 -%}
          {%- for block in section.blocks -%}
            {%- assign row_width = row_width | plus: block.settings.container_width -%}
            {%- if row_width > 100 -%}
            <div class="footer__clear small--hide"></div>
            {%- assign row_width = row_width | minus: 100 -%}
            {%- endif -%}
            <div {{ block.shopify_attributes }} class="grid__item  grid_{{ forloop.index }}" data-type="{{ block.type }}">
              {%- style -%}
              @media only screen and (min-width: 769px) and (max-width: 959px) {
                .grid__item {
                  width: 50%;
                  padding-top: 40px;
                }
                .grid__item:nth-child(2n + 1) {
                  clear: left;
                }
                }
                @media only screen and (min-width: 960px) {
                  .grid__item.grid_{{ forloop.index }} {
                    width: {{ block.settings.container_width }}%;
                  }

                }
              {%- endstyle -%}

              {%- case block.type %}
                {% when 'images' %}
                  {% if block.settings.image != blank %}<div class="image_block"><img src="{{ block.settings.image | img_url:'master' }}"></div>{% endif %}
                  {% if block.settings.image1 != blank %}<div class="image_block"><img src="{{ block.settings.image1 | img_url:'master' }}"></div>{% endif %}
                  {% if block.settings.image2 != blank %}<div class="image_block"><img src="{{ block.settings.image2 | img_url:'master' }}"></div>{% endif %}
                {% when 'video' %}
                  <div class="video_block">
                    <video width="100%" height="auto" autoplay muted playsinline loop preload="none">
                      <source src="{{ block.settings.video }}" type="video/mp4">
                      Your browser does not support the video tag.
                    </video>
                  </div>
              {% endcase %}
            </div>
          {%- endfor -%}
        </div>
      </div>
    </div>
  </div>
</section>
<style>
{% comment %} .image_with_video .grid{margin-left:-30px;}
.image_with_video  .grid__item{padding-left:30px;} {% endcomment %}
section.image_with_video {margin-bottom: 40px;}
video{max-width: 100%;width: 100%;}
.video_block.xbg {position: relative;overflow: hidden;}
div.image_block {padding-bottom: 18px;}
div.image_block:last-child {padding-bottom: 0px;}
.image_block img{width:100%;}
</style>
