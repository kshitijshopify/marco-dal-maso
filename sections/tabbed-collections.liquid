  "class": "index-section",
  "settings": [ 
    {
      "type": "select",
      "id": "tabsstyle",
      "label": "Tabs Style",
      "default": "textstyletabs",
      "options": [
        {
          "value": "styletabbuttons",
          "label": "Tabs as Buttons"
        },
        {
          "value": "textstyletabs",
          "label": "Tabs as plain text"
        }
      ]
    }, 
    {
      "type": "range",
      "id": "top_margin",
