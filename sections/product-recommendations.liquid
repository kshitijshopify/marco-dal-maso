<div id="tabmenu" class="recomm_recent_together">
  <ul id="nav" class="tabs">
    <li><a href="#tab-1">{{ section.settings.product_recommendations_heading }}</a></li>
    <li><a href="#tab-2">{{ 'products.general.recent_products' | t }}</a></li>
    {% if product.metafields.custom.product_look_book != blank %}<li><a href="#tab-3">{{ section.settings.title1 }}</a></li>{% endif %}
  </ul>
                     
  <div class="content" id="tab-1">
    {%- liquid
      assign recommend_products = true
    
      if recommendations.products and recommendations.products_count > 0
        assign related_collection = recommendations
      endif
    
      assign number_of_products = section.settings.related_count
    -%}
    
    <product-recommendations
      id="Recommendations-{{ section.id }}"
      data-section-id="{{ section.id }}"
      data-section-type="product-recommendations"
      data-enable="{{ recommend_products }}"
      data-product-id="{{ product.id }}"
      data-intent="related"
      data-url="{{ routes.product_recommendations_url }}?section_id={{ section.id }}&product_id={{ product.id }}&limit={{ number_of_products }}"
      data-limit="{{ number_of_products }}">
    
      <div
        data-section-id="{{ product.id }}"
        data-subsection
        data-section-type="collection-grid"
        class="index-section">
        <!-- <div class="page-width">
          <header class="section-header">
            <h3 class="section-header__title">
              {{ section.settings.product_recommendations_heading }}
            </h3>
          </header>
        </div> -->
    
        <div class="page-widthh">
          <div class="cdcd collection-grid__wrapper">
            {%- if recommend_products -%}
              <div class="product-recommendations-placeholder">
                {% comment %}
                  This content is visually hidden and replaced when recommended products show up
                {% endcomment %}
              <div class="grid-overflow-wrapper">
                <div class="grid grid--uniform" data-aos="overflow__animation" aria-hidden="true">                  
                  {%- render 'product-grid-item',
                    product: product,
                    quick_shop_enable: settings.quick_shop_enable
                  -%}
                </div>
              </div>
              </div>
            {%- endif -%}
            {%- if related_collection.products_count > 0 -%}
              <div class="product-recommendations page-width">
                <div class="grid-overflow-wrapper">
                <div class="grid grid--uniform" data-aos="overflow__animation" aria-hidden="true">
                  {%- for product in related_collection.products limit: number_of_products -%}
                    {% comment %} On smaller screen sizes, 39vw is used for grid items in the CSS {% endcomment %}
                    {%- render 'product-grid-item',
                      product: product,
                      per_row: section.settings.products_per_row,
                      quick_shop_enable: settings.quick_shop_enable,
                      fallback: '39vw',
                    -%}
                  {%- endfor -%}
                </div>
              </div>
              </div>
            {%- endif -%}
          </div>
        </div>
      </div>
    </product-recommendations>
  </div>
                      
  <div class="content" id="tab-2">
    {%- liquid
      assign row_of = section.settings.recent_count
    
      capture gridView
        render 'products_per_row', products_per_row: row_of, style: 'fractions'
      endcapture
    
      # On smaller screen sizes, 39vw is used for grid items in the CSS
      capture sizes
        render 'sizes-explicit', sizeVariable: gridView, fallback: '39vw'
      endcapture
    -%}
    
    <div
      data-subsection
      data-section-id="{{ section.id }}"
      data-section-type="recently-viewed"
      data-product-handle="{{ product.handle }}"
      data-recent-count="{{ section.settings.recent_count }}"
      data-grid-item-class="{{ gridView }}"
      data-row-of="{{ row_of }}"
      data-image-sizes="{{ sizes }}"
    >
      <div class="index-section index-section--small">
        <!-- <div class="page-width">
          <header class="section-header">
            <h2 class="section-header__title">{{ 'products.general.recent_products' | t }}</h2>
          </header>
        </div> -->
    
        <div class="page-widthh">
          <div class="grid-overflow-wrapper">
            <div id="RecentlyViewed-{{ section.id }}" class="grid grid--uniform" data-aos="overflow__animation"></div>
          </div>
        </div>
      </div>
    </div>
  </div>

  {% if product.metafields.custom.product_look_book != blank %}
    <div class="content" id="tab-3">    
    <div data-section-id="{{ product.id }}" data-subsection data-section-type="collection-grid" class="">
      <div class="product_rlatede_detail">
        {%  if section.settings.title1 != blank %}
        <!-- <div class="page-width">
          <header class="section-header">
            <h3 class="section-header__title">
             {{ section.settings.title1 }}
            </h3>
          </header>
        </div> -->
        {% endif %}
        <div class="grid grid--product-images--partial">
          <div class="grid__item medium-up--three-fifths ">  
            <div class="cdcd collection-grid__wrapper">
              <div class="product-recommendations">
                <div class="grid-overflow-wrapper">
                <div class="grid grid--uniform" data-aos="overflow__animation">
                  {% assign related_products = section.settings.product_list %}
                  {% assign quick_shop_onlybtn = true %}
                  {% for prod in related_products %}
                    {%- render 'product-grid-item',
                      product: prod, per_row: 3, quick_shop_onlybtn: quick_shop_onlybtn, fallback: '39vw', -%}
                  {% endfor %}
                </div></div>
              </div>
            </div>
          </div>
          <div class="relative  grid__item medium-up--two-fifths">
            <img class="pbimg" src="data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAQAAAC1HAwCAAAAC0lEQVR42mNkYAAAAAYAAjCB0C8AAAAASUVORK5CYII=" data-li="st" d-src="{{ section.settings.coll_image | img_url:'master'}}" width="" height="" alt="" loading="eager" />
            {% for prod in related_products %}
              <div class="dot_products dot_{{ forloop.index }}">
                <span class="dot_icon"></span>
                <div class="dot-product">
                  <a href="{{shop.url | append: "/products/" | append: prod.handle }}">
                    <div class="dot-product-name">{{prod.title}}</div>
                    <div class="dot-product-price">{{prod.price | money}}</div>
                  </a>
                </div>
              </div>
            {% endfor %}
          </div>
         </div>  
      </div>
    </div>
    
    <style>
    {{ section.settings.css | strip_html }}
    </style>
  </div>{% endif %}
</div>           



{% schema %}
{
  "name": "t:sections.product-recommendations.name",
  "settings": [
    {
      "type": "header",
      "content": "Get the Look"
    },
    {
      "type": "text",
      "id": "title1",
      "label": "Title",
      "default": "Get the Look"
    }, 
    {
      "type": "image_picker",
      "id": "coll_image",
      "label": "Get the Look Image",
      "info": "Link in the product metaobject entry through dynamic source."
    }, 
    {
      "type": "product_list",
      "id": "product_list",
      "label": "Products List",
      "info": "Link in the product metaobject entry through dynamic source."
    },
    {
      "type": "text",
      "id": "css",
      "label": "CSS for Dots Positioning"
    },
    {
      "type": "paragraph",
      "content": "t:sections.recently-viewed.settings.content"
    },
    {
      "type": "range",
      "id": "recent_count",
      "label": "t:sections.recently-viewed.settings.recent_count.label",
      "default": 5,
      "min": 2,
      "max": 10,
      "step": 1
    },
    {
      "type": "paragraph",
      "content": "t:sections.product-recommendations.settings.show_product_recommendations.info"
    },
    {
      "type": "text",
      "id": "product_recommendations_heading",
      "label": "t:sections.product-recommendations.settings.product_recommendations_heading.label",
      "default": "You may also like"
    },
    {
      "type": "range",
      "id": "related_count",
      "label": "t:sections.product-recommendations.settings.related_count.label",
      "default": 6,
      "min": 2,
      "max": 6,
      "step": 1
    },
    {
      "type": "range",
      "id": "products_per_row",
      "label": "t:sections.product-recommendations.settings.products_per_row.label",
      "default": 3,
      "min": 2,
      "max": 5,
      "step": 1
    }
  ],
  "disabled_on": {
    "groups": ["footer", "header", "custom.popups"]
  }
}
{% endschema %}
