function initVariantWrappers(context) {
  var $context = context ? $(context) : $(document);

  $context.find('.productgridclass .variant-wrapper').each(function () {
    var $wrapper = $(this);
    var $list = $wrapper.find('ul').first();

    // All product <li>, ignore any previous "+X" item
    var $items = $list.children('li').not('.js-variant-more');
    var visibleCount = 3;

    // Reset in case this runs again (Ajaxinate)
    $items.show();
    $list.find('.js-variant-more').remove();

    var total = $items.length;

    if (total > visibleCount) {
      // Hide everything after the first 3
      $items.slice(visibleCount).hide();

