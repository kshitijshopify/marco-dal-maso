document.addEventListener('DOMContentLoaded', function () {
  var descriptionEl = document.querySelector('.collection-description');

  if (!descriptionEl) return;

  // 2. HOW TALL IS "COLLAPSED" STATE? (must match CSS max-height)
  var collapsedMaxHeight = 180; // in px — keep in sync with CSS

  // If content is already shorter than collapsed height, do nothing
  if (descriptionEl.scrollHeight <= collapsedMaxHeight + 5) {
    return;
  }

  // 3. START CLAMPED
  descriptionEl.classList.add('collection-description--clamped');

  // 4. CREATE THE TOGGLE BUTTON
  var toggleBtn = document.createElement('button');
  toggleBtn.type = 'button';
  toggleBtn.className = 'collection-description-toggle';
  toggleBtn.textContent = 'Read more';

  var expanded = false;

  toggleBtn.addEventListener('click', function () {
    expanded = !expanded;

    if (expanded) {
      descriptionEl.classList.remove('collection-description--clamped');
      toggleBtn.textContent = 'Read less';
    } else {
      descriptionEl.classList.add('collection-description--clamped');
      toggleBtn.textContent = 'Read more';
    }
  });

  // 5. INSERT THE BUTTON AFTER THE DESCRIPTION (HTML stays untouched)
  descriptionEl.insertAdjacentElement('afterend', toggleBtn);
});

/****RebuyCart Drawer*** */
document.addEventListener('DOMContentLoaded', function() {
  // Function to transform variant titles
  function transformVariantTitles() {
    const variantTitles = document.querySelectorAll('.rebuy-cart__flyout-item-variant-title');
    
    variantTitles.forEach(function(element) {
      const variantText = element.textContent.trim();
      
      // Skip if already transformed or empty
      if (!variantText || variantText.includes(':')) return;
      
      // Split variant title by " / " to get individual options
      const options = variantText.split(' / ');
      
      // Common option names mapping
      const optionNames = ['Size', 'Color', 'Style', 'Material'];
      
      // Transform each option
      const transformedOptions = options.map(function(option, index) {
        const optionName = optionNames[index] || 'Option ' + (index + 1);
        return optionName + ': ' + option;
      });
      
      // Update the element
      element.textContent = transformedOptions.join(' / ');
    });
  }
  
  // Run initially
  transformVariantTitles();
  
  // Run when cart updates (using MutationObserver)
  const observer = new MutationObserver(transformVariantTitles);
  observer.observe(document.body, { childList: true, subtree: true });
});
