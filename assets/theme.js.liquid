function setPromoHeight(tries) {
  tries = tries || 0;
  if (tries > 20) return; // safety, don't loop forever

  // Take the first *visible* product link
  var $src = $('.grid-product__image-mask:visible').first();

  if (!$src.length) {
    setTimeout(function () { setPromoHeight(tries + 1); }, 300);
    return;
  }

  // Use outerHeight so padding is included
  var h = $src.outerHeight();
  
  if (h > 0) {
    $('.collection-promo--root[data-textpos="below_image"] .imagebnrr__promotion').height(h);
    $('.collection-promo--root[data-textpos="above_image"] .imagebnrr__promotion').height(h);
    $('.collection-promo--root[data-textpos="absoluted_onimage"] .imagebnrr__promotion').height(h);
  } else {
    setTimeout(function () { setPromoHeight(tries + 1); }, 300);
  }
}

