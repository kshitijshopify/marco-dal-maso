$('.similar_p_v .variant-wrapper span').click(function(){
  $(this).slideToggle();
  $(this).parent('.variant-wrapper').find('ul').slideToggle();
  $(this).parent('.variant-wrapper').find('.closebtn').slideToggle();
});
$('.similar_p_v .variant-wrapper .closebtn').click(function(){
  $(this).slideToggle();
  $(this).parent('.variant-wrapper').find('ul').slideToggle();
  $(this).parent('.variant-wrapper').find('span').slideToggle();
});
$('.variant-wrapper ul a').on("click", function () {
  var dtimg = $(this).data('img');
  var dtmeta = $(this).data('title');
  var dtprice = $(this).data('price');
  var dturl = $(this).data('href');console.log(dturl);
  $(this).parent().parent('ul').find('li').removeClass('activeprod');
  var datasrcset = dtimg +'&width=360 360w,' + dtimg + '&width=540 540w,' + dtimg + '&width=720 720w,'+ dtimg + '&width=900 900w,'+ dtimg + '&width=1080 1080w,';
