theme.ShippingBar = (function () {

  var bar = document.querySelector('.free-shipping-bar');
  var progressbar = document.querySelector('.shipping-bar');

  // 🚨 Critical guard
  if (!bar || !progressbar) {
    return {
      update: function () {
        // do nothing safely
      }
    };
  }

  var promote_txt  = bar.dataset.promote || '';
  var unlocked_txt = bar.dataset.unlocked || '';
  var threshold    = parseInt(bar.dataset.threshold, 10) || 0;

  function update() {
    return $.getJSON('/cart.js').then(function (cart) {

      if (!cart || !cart.total_price) return;

      var val_left = threshold - cart.total_price;
      var val_left_money = theme.Currency.formatMoney(
        Math.max(val_left, 0),
        theme.settings.moneyFormat
      );

      if (val_left <= 0) {
        bar.innerHTML =
          '<span class="shipping-bar__text text--small unlockedjs unlocked">' +
          unlocked_txt +
          '</span>';
      } else {
        bar.innerHTML =
          '<span class="shipping-bar__text text--small promojs">' +
          promote_txt.replace('[value]', val_left_money) +
          '</span>';
      }

      progressbar.style.setProperty(
        '--progress',
        Math.min(cart.total_price / threshold, 1)
      );
    });
  }

  return { update: update };

})();


      $('.md-sticky-prd .add-to-cart').click(function(e){
      e.preventDefault();
        var selval =  $('.select_pop').val();
        if (selval !== null && selval !== "") {

            $.ajax({
                type: 'POST',
                url: '/cart/add.js',
                data: {
                    id: selval,      // variant ID
                    quantity: 1
                },
                dataType: 'json',
                success: function (item) {
                    console.log("Added to cart", item);
        
                    new theme.CartDrawer();
                    $('html').addClass('js-drawer-open');
                    $('#CartDrawer').addClass('drawer--is-open');

                },
                error: function (xhr) {
                    console.error("Error adding to cart:", xhr.responseText);
                }
            });


        }else{
          $('.show_error_msg').addClass('active');
              setTimeout(function() {
                        $('.show_error_msg').removeClass('active');
              }, 3000);
        }
    });
})();

