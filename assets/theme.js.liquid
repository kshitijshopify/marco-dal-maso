// Initialize all product sliders
// Init Slick for collection product carousels
function initCollectionSliders($scope) {
  var $root = $scope || $(document);

  $root.find('.js-product-slider').each(function () {
    var $slider = $(this);

    // Avoid re-initializing
    if ($slider.hasClass('slick-initialized')) return;

    $slider.slick({
      slidesToShow: 1,
      slidesToScroll: 1,
      arrows: true,
      dots: false,
      infinite: true,
      speed: 300,
      adaptiveHeight: false,
      // optional: disable swipe on desktop if you like
      swipeToSlide: true,
      touchThreshold: 10,prevArrow: '<button type="button" class="slick-prev"> <svg width="10" height="20" viewBox="0 0 10 20" fill="none" xmlns="http://www.w3.org/2000/svg"> <path d="M9.75595 1.0774C10.0813 1.40278 10.0814 1.93047 9.75587 2.25589L2.01183 9.99979L9.75595 17.744C10.0813 18.0694 10.0814 18.5971 9.75587 18.9225C9.43042 19.248 8.9028 19.248 8.57739 18.9225L0.244062 10.589C0.0877991 10.4327 0 10.2208 0 9.99979C0 9.77878 0.0878353 9.56681 0.244099 9.41058L8.57742 1.07747C8.90284 0.751945 9.43049 0.751944 9.75595 1.0774Z" fill="#090909"/> </svg> </button>',
  nextArrow: '<button type="button" class="slick-next"> <svg width="10" height="20" viewBox="0 0 10 20" fill="none" xmlns="http://www.w3.org/2000/svg"> <path d="M0.244054 1.07752C-0.0813273 1.4029 -0.0813989 1.93059 0.244125 2.25601L7.98817 9.99991L0.244054 17.7442C-0.0813273 18.0695 -0.0813989 18.5972 0.244125 18.9227C0.569578 19.2481 1.0972 19.2481 1.42261 18.9227L9.75594 10.5891C9.9122 10.4329 10 10.2209 10 9.99991C10 9.77891 9.91216 9.56693 9.7559 9.4107L1.42258 1.07759C1.09716 0.752068 0.569506 0.752066 0.244054 1.07752Z" fill="black"/> </svg> </button>'        
    });

    // Prevent card-level click handlers from hijacking slider clicks
    $slider.on('click mousedown touchstart pointerdown', function (e) {
      e.stopPropagation();
    });
  });
}

