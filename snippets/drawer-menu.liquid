      <button id="myButton2"><selector-root data-id=PH712938 id="PH712938"></selector-root></button>
              <script>
document.getElementById("myButton2").addEventListener("click", function() {
window.$selector.push(["do", "markets-recommendations:show"]);
});
</script>
      {%- liquid
        assign show_selectors = false
        assign currency_selector = false

        if section.settings.show_currency_selector and shop.enabled_currencies.size > 1
          assign currency_selector = true
        endif

        if currency_selector
          assign show_selectors = true
        endif
      -%}
      {%- if show_selectors -%}
        <div class="toolbar{% if overlay_header%} toolbar--transparent{% endif %}">
          <div class="toolbar__content">
            <div class="toolbar__item">
              {%- render 'multi-selectors',
                locale_selector: locale_selector,
                currency_selector: currency_selector,
                show_currency_flags: section.settings.show_currency_flags
                location: 'drawer'
              -%}
            </div>
            {% comment %} <div class="toolbar__item"><p>Language: </p><div id="glc-switcher-manual-mobile"></div></div> {% endcomment %}
