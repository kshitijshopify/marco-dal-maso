                              <div class="megapromo__griditem">
                                <div class="small--hide">
                                {% if megaLink %}
                                <a href="{{ megaLink }} ">
                                {% endif %}
                                  {{ menuImage | replace: ' src="' , ' src="data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAQAAAC1HAwCAAAAC0lEQVR42mNkYAAAAAYAAjCB0C8AAAAASUVORK5CYII=" data-li="st" d-src="' | replace: ' srcset="' , ' dt="' }}
                                  <div class="megapromo__textbox">
                                    <div class="rte">{{ subText }}</div>
                                    <span>{{ buttonLabel }}</span>
                                  </div>
                                {% if megaLink %}
                                </a>
                                {% endif %}
                                </div>

                                                                
