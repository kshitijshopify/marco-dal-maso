                          <div class="tyr menupromo__image megatype2promo menu_img_block imageContainerBox appear-animation appear-delay-{{ animation_column }}">
                            <div class="menupromo__inner">
                              <div class="megapromo__griditem">
                                {% if megaLink %}
                                <a href="{{ megaLink }} ">
                                {% endif %}
                                  {{ menuImage }}
