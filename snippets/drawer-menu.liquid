                            </div>
                          </div>
                          <div class="subcatmenus subcatmenus__megatype2promo grid__item medium-up--one-fifth  appear-animation appear-delay-{{ animation_column }}">  
                            <div class="textblock__megapromo">
                              <div class="rte">
                                {{ block.settings.descriptionarea }}
                              </div>
                              <a href="{{ block.settings.textlink }}" class="">{{ block.settings.textlabel }}</a>
                            </div>
                          </div>
                        {% endif %}
                      {% endif %}
                    {% endif %}
                  {% endfor %}
                  <div class="collapsible-content__inner">
                    <ul class="mobile-nav__sublist">
                      {% if link.levels > 1 %}       
                        {% unless link.title == 'Collections' or link.title == "Marco's World" %}                    
                        <li class="mobile-nav__item   {% if forloop.first %}at_bottom {% endif %} fixedmenuitems">
                          <a href="{{ link.url }}" class="mobile-nav__link" id="Sublabel-1">
                            Discover All {{ link.title }}
                          </a>
                        </li>                    
                        {% endunless %}
                      {% endif %}
                      
                      {% if link.title == 'Collections' or link.title == 'collections' %}
                        <div class="collectionslist__menu">
                          <div class="mobile-nav__child-item mobile-nav__child-item-collections{{ forloop.index }}">                          
                            <a href="{{ link.url }}" class="mobile-nav__link" id="Sublabel-1">
                                Discover All {{ link.title }}
                            </a>
                          </div>
                      {% endif %}
                      {%- for childlink in link.links -%}
                        {%- assign has_sub_dropdown = false -%}
                        {%- assign grand_child_list_handle = childlink.url | handleize | append: forloop.index -%}
                        {%- if childlink.links != blank -%}
                          {%- assign has_sub_dropdown = true -%}
                        {%- endif -%}
                        <li class="mobile-nav__item cc r55">
                          {% unless link.title == 'Collections' or link.title == 'collections' %}
                            <div class="mobile-nav__child-item">
                              {%- if childlink.url == '#' and has_sub_dropdown -%}
                                {% if link.title != 'Gifts' %}
                                <button type="button"
                                aria-controls="Sublinklist-{{ child_list_handle }}-{{ grand_child_list_handle }}"{% if childlink.active or childlink.child_active %} aria-open="true"{% endif %}
                                class="mobile-nav__link--button  collapse_label_2 collapsible--trigger {% if childlink.active or childlink.child_active %} is-open{% endif %}">
                                  <span class="mobile-nav__faux-link"{% if childlink.active %} data-active="true"{% endif %}>{{ childlink.title | escape }}</span>
                                
                                </button>
                                  {% endif %}
                              {%- else -%}
                                <a href="{{ childlink.url }}"
                                  class="mobile-nav__link"
                                  id="Sublabel-{{ grand_child_list_handle }}"
                                  {% if childlink.active %}data-active="true"{% endif %}>
                                  {{ childlink.title | escape }}
                                </a>
                              {%- endif -%}
                            </div>
                          
                            {%- if has_sub_dropdown -%}
                              <div
                                id="Sublinklist-{{ child_list_handle }}-{{ grand_child_list_handle }}"
                                aria-labelledby="Sublabel-{{ grand_child_list_handle }}"
                                class="mobile_sub_3 mobile-nav__sublist collapsible-content collapsible-content--all is-open{% if childlink.active or childlink.child_active or link.title == 'Gifts' %} is-open{% endif %}"
                                {% if childlink.active or childlink.child_active %}style="height: auto;"{% endif %}>
                                <div class="collapsible-content__inner">
                                  <ul class="mobile-nav__grandchildlist">
                                    {%- for grandchildlink in childlink.links -%}
                                      <li class="mobile-nav__item mm">
                                        <a href="{{ grandchildlink.url }}" class="mobile-nav__link"{% if grandchildlink.active %} data-active="true"{% endif %}>
                                          {{ grandchildlink.title }}
                                        </a>
                                      </li>
                                    {%- endfor -%}
                                  </ul>
                                </div>
                              </div>
                            {%- endif -%}
                          {% else %}                          
                            <ul class="mobile-nav__grandchildlist">
                                  {%- for grandchildlink in childlink.links -%}
                                    <li class="mobile-nav__item mm">
                                      <a href="{{ grandchildlink.url }}" class="mobile-nav__link"{% if grandchildlink.active %} data-active="true"{% endif %}>
                                        {{ grandchildlink.title }}
                                      </a>
                                    </li>
                                  {%- endfor -%}
                                </ul>
                          {% endunless %}
                        </li>
                      {%- endfor -%}
                          {% if link.title == 'Collections' or link.title == 'collections' %}
                        </div>
                      {% endif %}
                    </ul>
                  </div>
