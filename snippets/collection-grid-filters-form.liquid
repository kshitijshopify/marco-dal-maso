                          <span>
                              <span class="tag__text">{{ filter_value.label | remove: 'Finish_' | remove: 'finish_' }}</span>
                               {% comment %} ({{ filter_value.count }}) {% endcomment %}
                          </span>
                          {%- endif -%}
                      </label>
                    </li>
                    {% endif %}
                  {%- endfor -%}
                  </ul>

                  {%- if stonetag_count == 0 -%}
                    {%- style -%}
                        .collection-sidebar__group--{{ filter_index }} { display: none; }
                    {%- endstyle -%}
                  {%- endif -%}
                
            </div>
          </div>
        </div>
      </div>
    {% endif %}
  {%- endfor -%}
  
  {%- for filter in filters -%}
    {% if filter.label == 'More filters' %}
      {%- capture filter_id -%}filter-color{%- endcapture -%}
      {%- assign filter_index = 7 -%}
    
      <div class="stones_total_{{ stonetag_count }} collection-sidebar__group--{{ filter_index }}">
        <div class="collection-sidebar__group">
          <button
              type="button"
              class="collapsible-trigger collapsible-trigger-btn collapsible--auto-height{% unless collapsed %} is-open{% endunless %} tag-list__header"
