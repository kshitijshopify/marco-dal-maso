{% comment %}
- filters: Liquid 'collection.filters' or 'search.filters' object
- enable_color_swatches: boolean
- collapsed: boolean
{% endcomment %}
{% liquid
  if collection.products
    assign count = collection.products_count
    assign count_label = 'collections.general.items_with_count'
  endif
%}
{% comment %} <h4 class="h3">Filter by</h4> {% endcomment %}
<form class="filter-form">
  {%- for filter in filters -%}
    {% if filter.label == 'More filters' %}
      {%- capture filter_id -%}filter-metal{%- endcapture -%}
      {%- assign filter_index = 5 -%}
      <div class="collection-sidebar__group--{{ filter_index }}">
        <div class="collection-sidebar__group">
          <button
              type="button"
              class="collapsible-trigger collapsible-trigger-btn collapsible--auto-height{% unless collapsed %} is-open{% endunless %} tag-list__header"
              aria-controls="{{ location }}-{{ filter_index }}{% if filter_id %}-{{ filter_id }}{% endif %}"
              data-collapsible-id="{{ filter_id }}">
              Metal
              {%- render 'collapsible-icons' -%}
          </button>
          <div
          id="{{ location }}-{{ filter_index }}-{{ filter_id }}"
          class="collapsible-content collapsible-content--sidebar{% unless collapsed %} is-open{% endunless %}"
          data-collapsible-id="{{ filter_id }}"
          >
            <div class="collapsible-content__inner">
                  {%- liquid
                    assign is_color = false
                    assign swatch_file_extension = 'png'
                    if enable_color_swatches
                        assign swatch_trigger = 'more filters'
                        assign downcased_label = filter.label | downcase
                        if downcased_label contains swatch_trigger
                        assign is_color = true
                        elsif swatch_trigger == 'color' and downcased_label contains 'colour'
                        assign is_color = true
                        endif
                    endif
                  -%}

                  <ul class="swatched_filters no-bullets tag-list">
                  {%- assign metaltag_count = 0 -%}
                  {%- for filter_value in filter.values -%}
                    {% if filter_value.value contains 'Metal' %}
                      {%- liquid
                      assign metaltag_count = metaltag_count | plus: 1
                      assign filter_value_index = forloop.index
      
                      assign color_file_name = filter_value.label | replace: "_", " " | handle | append: '.' | append: swatch_file_extension
                      assign color_image = color_file_name | file_img_url: '50x50' | prepend: 'https:' | split: '?' | first
                      assign color_swatch_fallback = filter_value.label | split: ' ' | last | handle
                    -%}
                    {% unless filter_value.value contains 'enamel' or filter_value.value contains 'Enamel' %}
                      <li class="{{ metaltag_count }} tag{% if filter_value.active %} tag--active{% endif %}{% if is_color %} tag--swatch{% endif %}{% if filter_value.count == 0%} hide{% endif %}">
                        <label class="tag__checkbox-wrapper text-label">
                            <input
                            type="checkbox"
                            class="tag__input"
                            name="{{ filter_value.param_name }}"
                            value="{{ filter_value.value }}"
                            {% if filter_value.active %}checked{% endif %}>
                            {%- if is_color -%}
                            <span
                                class="color-swatch color-swatch--filter color-swatch--{{ filter_value.label | handle }}"
                                title="{{ filter_value.label }}"
                                style="background-color: {{ color_swatch_fallback }};background-image: url({{ color_image }});"
                            >
                                {{ filter_value.label | remove: 'Metal_' | remove: 'metal_' }}
                            </span>
                            <span class="tag__text">{% if filter_value.label contains 'rose gold' or filter_value.label contains 'Rose Gold' or filter_value.label contains 'ROSE GOLD' %}18kt {% endif %}{{ filter_value.label | remove: 'Metal_' | remove: 'metal_' }}</span>
                            {%- else -%}
                            <span class="tag__checkbox"></span>
                            <span>
                                <span class="tag__text">{{ filter_value.label | remove: 'Metal_' | remove: 'metal_' }}</span> 
                                {% comment %} ({{ filter_value.count }}) {% endcomment %}
                            </span>
                            {%- endif -%}
                        </label>
                      </li>
                      {% endunless %}
                    {% endif %}
                  {%- endfor -%}
                  </ul>

                  {%- if metaltag_count == 0 -%}
                    {%- style -%}
                        .collection-sidebar__group--{{ filter_index }} { display: none; }
                    {%- endstyle -%}
                  {%- endif -%}
                
            </div>
          </div>
        </div>
      </div>
    {% endif %}
  {%- endfor -%}

  {%- for filter in filters -%}
    {% if filter.label == 'More filters' %}
      {%- capture filter_id -%}filter-stone{%- endcapture -%}
      {%- assign filter_index = 6 -%}

      <div class="metals_total_{{ metaltag_count }} collection-sidebar__group--{{ filter_index }}">
        <div class="collection-sidebar__group">
          <button
              type="button"
              class="collapsible-trigger collapsible-trigger-btn collapsible--auto-height{% unless collapsed %} is-open{% endunless %} tag-list__header"
              aria-controls="{{ location }}-{{ filter_index }}{% if filter_id %}-{{ filter_id }}{% endif %}"
              data-collapsible-id="{{ filter_id }}">
              Stone
              {%- render 'collapsible-icons' -%}
          </button>
          <div
          id="{{ location }}-{{ filter_index }}-{{ filter_id }}"
          class="collapsible-content collapsible-content--sidebar{% unless collapsed %} is-open{% endunless %}"
          data-collapsible-id="{{ filter_id }}"
          {% unless collapsed %}style="height: auto;"{% endunless %}>
            <div class="collapsible-content__inner">
                  {%- liquid
                    assign is_color = false
                    assign swatch_file_extension = 'png'
                    if enable_color_swatches
                        assign swatch_trigger = 'more filters'
                        assign downcased_label = filter.label | downcase
                        if downcased_label contains swatch_trigger
                        assign is_color = true
                        elsif swatch_trigger == 'color' and downcased_label contains 'colour'
                        assign is_color = true
                        endif
                    endif
                  -%}

                  <ul class="swatched_filters no-bullets tag-list">
                  {%- assign stonetag_count = 0 -%}
                  {%- for filter_value in filter.values -%}
                    {% if filter_value.value contains 'Stone' %}
                    {%- liquid
                    assign stonetag_count = stonetag_count | plus: 1
                    assign filter_value_index = forloop.index

                    assign color_file_name = filter_value.label | replace: "_", " " | handle | append: '.' | append: swatch_file_extension
                    assign color_image = color_file_name | file_img_url: '50x50' | prepend: 'https:' | split: '?' | first
                    assign color_swatch_fallback = filter_value.label | split: ' ' | last | handle
                  -%}
                    
                    <li class="tag{% if filter_value.active %} tag--active{% endif %}{% if is_color %} tag--swatch{% endif %}{% if filter_value.count == 0%} hide{% endif %}">
                      <label class="tag__checkbox-wrapper text-label">
                          <input
                          type="checkbox"
                          class="tag__input"
                          name="{{ filter_value.param_name }}"
                          value="{{ filter_value.value }}"
                          {% if filter_value.active %}checked{% endif %}>
                          {%- if is_color -%}
                          <span
                              class="color-swatch color-swatch--filter color-swatch--{{ filter_value.label | handle }}"
                              title="{{ filter_value.label }}"
                              style="background-color: {{ color_swatch_fallback }};background-image: url({{ color_image }});"
                          >
                              {{ filter_value.label | remove: 'Stone_' | remove: 'stone_' }}
                          </span>
                          <span class="tag__text">{{ filter_value.label | remove: 'Stone_' | remove: 'stone_' }}</span>
                          {%- else -%}
                          <span class="tag__checkbox"></span>
                          <span>
                              <span class="tag__text">{{ filter_value.label | remove: 'Stone_' | remove: 'stone_' }}</span> 
                              {% comment %} ({{ filter_value.count }}) {% endcomment %}
                          </span>
                          {%- endif -%}
                      </label>
                    </li>
                    {% endif %}
                  {%- endfor -%}
                  </ul>

                  {%- if stonetag_count == 0 -%}
                    {%- style -%}
                        .collection-sidebar__group--{{ filter_index }} { display: none; }
                    {%- endstyle -%}
                  {%- endif -%}
                
            </div>
          </div>
        </div>
      </div>
    {% endif %}
  {%- endfor -%}

  {%- for filter in filters -%}
    {% if filter.label == 'More filters' %}
      {%- capture filter_id -%}filter-finish{%- endcapture -%}
      {%- assign filter_index = 6 -%}

