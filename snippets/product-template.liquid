                                    <svg aria-hidden="true" focusable="false" role="presentation" xmlns="http://www.w3.org/2000/svg" class="icon icon-accordion icon-recycle" viewBox="0 0 20 20"><path d="M10.706.55c.3 0 .6 0 .867-.002 1.099-.013 1.844.78 2.138 1.286l1.68 2.804.776-.409a.5.5 0 0 1 .707.601L15.53 8.852a.5.5 0 0 1-.58.33l-4.36-.938a.5.5 0 0 1-.156-.916l.912-.557-.856-1.417-1.322 2.285a.5.5 0 0 1-.674.188L5.465 6.15a.5.5 0 0 1-.184-.7c.477-.775 1.365-2.304 1.945-3.307.295-.51.583-.878.897-1.13A2 2 0 0 1 9.148.575c.328-.028.944-.027 1.558-.026m.219 3.587L12.46 6.68a.5.5 0 0 1-.168.685l-.268.164 2.7.582.807-2.417-.094.049a.5.5 0 0 1-.661-.186l-1.93-3.219c-.2-.348-.67-.797-1.262-.79a76 76 0 0 1-.958.002c-.567 0-1.087-.002-1.377.021a1 1 0 0 0-.498.22l-.078.068c.738.315 1.67 1.001 2.252 2.278m-2.864-1.44c-.48.832-1.166 2.011-1.657 2.83L8.55 6.715 9.916 4.35c-.55-1.048-1.376-1.503-1.855-1.653m10.837 13.658c-.153.259-.307.517-.44.747-.549.952-1.611 1.19-2.196 1.184l-3.268.017-.044.876a.5.5 0 0 1-.878.302l-2.776-3.206a.5.5 0 0 1 .011-.666l3.03-3.274a.5.5 0 0 1 .867.333l.015 1.068 1.656-.014-1.293-2.302a.5.5 0 0 1 .182-.676l2.986-1.752a.5.5 0 0 1 .695.198 198 198 0 0 0 1.855 3.36c.289.512.458.948.516 1.347a2 2 0 0 1-.146 1.104c-.144.297-.458.826-.772 1.354m-3.198-1.64-2.97.025a.5.5 0 0 1-.504-.493l-.004-.315-1.877 2.027 1.669 1.927.005-.106a.5.5 0 0 1 .497-.475l3.753-.019c.401.004 1.028-.171 1.323-.684.157-.27.325-.554.486-.825.29-.487.556-.935.684-1.196a1 1 0 0 0 .064-.54l-.018-.102c-.647.474-1.712.926-3.108.777m2.698-1.73a243 243 0 0 1-1.59-2.868l-2.114 1.241 1.337 2.381c1.182.061 1.995-.418 2.367-.753M1.156 15.735a72 72 0 0 0-.427-.754c-.55-.952-.224-1.99.073-2.494l1.62-2.839-.737-.476a.5.5 0 0 1 .177-.911l4.164-.801a.5.5 0 0 1 .572.343l1.32 4.26a.5.5 0 0 1-.721.585l-.933-.521-.816 1.44 2.64.031a.5.5 0 0 1 .494.497l.025 3.462a.5.5 0 0 1-.519.503c-.91-.035-2.678-.06-3.837-.073-.588-.007-1.05-.079-1.425-.228a2 2 0 0 1-.883-.679c-.185-.272-.487-.81-.787-1.345m3.02-1.95 1.463-2.584a.5.5 0 0 1 .68-.19l.274.154-.817-2.639-2.503.482.09.057a.5.5 0 0 1 .162.668l-1.86 3.26c-.205.345-.366.976-.07 1.488.157.27.318.558.472.833.277.495.532.95.694 1.19.113.142.24.247.436.326q.045.018.097.035c-.088-.797.054-1.945.881-3.08m.148 3.202c.962.012 2.325.03 3.28.057l-.018-2.452-2.73-.032c-.645.993-.636 1.937-.532 2.427"/></svg>
                                  -->
                              {% endcase %}

                              <span>
                                {% if block.settings.code2 != blank %}
                                  {{ block.settings.code2 }}
                                {% else %}
                                  {{ block.settings.text2 }}
                                {% endif %}
                              </span>
                            </span>
                          </li>
                        {%- endunless -%}
                        {% if product.metafields.custom.enable_lab_grown_diamonds.value == true %}
                          <li class="sales-point">
                            <span class="icon-and-text">
                              {% if block.settings.content2 != blank %}
                                <tool-tip-trigger class="tool-tip-trigger" data-tool-tip="desc-popups">
                                  <div class="tool-tip-trigger__title">
                                    <img
                                      class="img_icon"
                                      src="https://cdn.shopify.com/s/files/1/1476/0022/files/rsz_lab_grown_diamonds-removebg-preview.png?v=1747140375"
                                      alt="Lab grown Diamonds"
                                    >
                                    <span>{{ block.settings.diamonds_text }}</span>
                                  </div>
                                  <span
                                    class="tool-tip-trigger__content"
                                    data-tool-tip-content=""
                                  >
                                    {{ block.settings.content2 }}
                                  </span>
                                </tool-tip-trigger>
                              {% else %}
                                <img
                                  class="img_icon"
                                  src="https://cdn.shopify.com/s/files/1/1476/0022/files/rsz_lab_grown_diamonds-removebg-preview.png?v=1747140375"
                                  alt="Lab grown Diamonds"
                                >
                                <span>{{ block.settings.diamonds_text }}</span>
                              {% endif %}
                            </span>
                          </li>
                        {% endif %}
                        {% if product.metafields.custom.enable_what_is_vermeil.value == true %}
                          <li class="sales-point">
                            <span class="icon-and-text">
                              {% if block.settings.content1 != blank %}
                                <tool-tip-trigger class="tool-tip-trigger" data-tool-tip="desc-popups">
                                  <div class="tool-tip-trigger__title">
                                    <img
                                      class="img_icon"
                                      src="https://cdn.shopify.com/s/files/1/1476/0022/files/rsz_vermeil-removebg-preview.png?v=1747140921"
                                      alt="MONETA Vermeil Initial W Ring"
                                    >
                                    <span>{{ block.settings.vermeil_text }}</span>
                                  </div>
                                  <span
                                    class="tool-tip-trigger__content"
                                    data-tool-tip-content=""
                                  >
                                    {{ block.settings.content1 }}
                                  </span>
                                </tool-tip-trigger>
                              {% else %}
                                <img
                                  class="img_icon"
                                  src="https://cdn.shopify.com/s/files/1/1476/0022/files/rsz_vermeil-removebg-preview.png?v=1747140921"
                                  alt="MONETA Vermeil Initial W Ring"
                                >
                                <span>{{ block.settings.vermeil_text }}</span>
                              {% endif %}
                            </span>
                          </li>
                        {% endif %}
                        {% if product.metafields.custom.enable_naturals_pearls.value == true %}
                          <li class="sales-point">
                            <span class="icon-and-text">
                              {% if block.settings.content3 != blank %}
                                <tool-tip-trigger class="tool-tip-trigger" data-tool-tip="desc-popups">
                                  <div class="tool-tip-trigger__title">
                                    <img
                                      class="img_icon"
                                      src="https://cdn.shopify.com/s/files/1/1476/0022/files/rsz_natural_pearls-removebg-preview.png?v=1747141421"
                                      alt="MONETA Vermeil Initial W Ring"
                                    >
                                    <span>{{ block.settings.pearls_text }}</span>
                                  </div>
                                  <span
                                    class="tool-tip-trigger__content"
                                    data-tool-tip-content=""
                                  >
                                    {{ block.settings.content3 }}
                                  </span>
                                </tool-tip-trigger>
                              {% else %}
                                <img
                                  class="img_icon"
                                  src="https://cdn.shopify.com/s/files/1/1476/0022/files/rsz_natural_pearls-removebg-preview.png?v=1747141421"
                                  alt="MONETA Vermeil Initial W Ring"
                                >
                                <span>{{ block.settings.pearls_text }}</span>
                              {% endif %}
                            </span>
                          </li>
                        {% endif %}
                        {% if product.metafields.custom.enable_vegan_leather.value == true %}
                          <li class="sales-point">
                            <span class="icon-and-text">
                              {% if block.settings.content4 != blank %}
                                <tool-tip-trigger class="tool-tip-trigger" data-tool-tip="desc-popups">
                                  <div class="tool-tip-trigger__title">
                                    <img
                                      class="img_icon"
                                      src="https://cdn.shopify.com/s/files/1/1476/0022/files/rsz_vegan_leather-removebg-preview.png?v=1747141420"
                                      alt="MONETA Vermeil Initial W Ring"
                                    >
                                    <span>{{ block.settings.leather_text }}</span>
                                  </div>
                                  <span
                                    class="tool-tip-trigger__content"
                                    data-tool-tip-content=""
                                  >
                                    {{ block.settings.content4 }}
                                  </span>
                                </tool-tip-trigger>
                              {% else %}
                                <img
                                  class="img_icon"
                                  src="https://cdn.shopify.com/s/files/1/1476/0022/files/rsz_vegan_leather-removebg-preview.png?v=1747141420"
                                  alt="MONETA Vermeil Initial W Ring"
                                >
                                <span>{{ block.settings.leather_text }}</span>
                              {% endif %}
                            </span>
                          </li>
                        {% endif %}
                      </ul>
                    </div>
                    {%- assign variants_with_inventory_tracking = product.variants
                      | where: 'inventory_management', 'shopify'
                    -%}

                    <script>
                      // Store inventory quantities in JS because they're no longer
                      // available directly in JS when a variant changes.
                      // Have an object that holds all potential products so it works
                      // with quick view or with multiple featured products.
                      window.inventories = window.inventories || {};
                      window.inventories['{{ product.id }}'] = {};
                      {% for variant in variants_with_inventory_tracking %}
                        window.inventories['{{ product.id }}'][{{ variant.id }}] = {
                          'quantity': {{ variant.inventory_quantity | default: 0 }},
                          'policy': '{{ variant.inventory_policy | default: false }}',
                          'incoming': '{{ variant.incoming | default: false }}',
                          'next_incoming_date': {{ variant.next_incoming_date | date: format: 'date' | json }}
                        };
                      {% endfor %}
                    </script>

                    {% comment %}
                      If loaded in quick view, it might be from a JS-loaded function
                      that loads recommended products. If that's the case, the above
                      JS will not set the variant inventory. Add it to an accessible
                      data div to read later instead.
                    {% endcomment %}
                    <div
                      data-product-id="{{ product.id }}"
                      class="hide js-product-inventory-data"
                      aria-hidden="true"
                    >
                      {%- for variant in variants_with_inventory_tracking -%}
                        <div
                          class="js-variant-inventory-data"
                          data-id="{{ variant.id }}"
                          data-quantity="{{ variant.inventory_quantity | default: 0 }}"
                          data-policy="{{ variant.inventory_policy | default: false }}"
                          data-incoming="{{ variant.incoming | default: false }}"
                          data-date="{{ variant.next_incoming_date | date: format: 'date' }}"
                        ></div>
                      {%- endfor -%}
                    </div>
                  {%- when 'inventory_status' -%}
                    {%- render 'product-inventory', product: product, current_variant: current_variant, block: block -%}
                  {%- when 'share' -%}
                    <div class="product-block" {{ block.shopify_attributes }}>
                      {%- render 'social-sharing',
                        share_title: product.title,
                        share_permalink: product.url,
                        share_image: product
                      -%}
                    </div>
                  {%- when 'complementary_products' -%}
                    <div class="product-block" {{ block.shopify_attributes }}>
                      {%- render 'product-complementary',
                        block: block,
                        product: product,
                        type: 'block',
                        image_style: block.settings.image_style
                      -%}
                    </div>
                  {%- when 'trust_badge' -%}
                    <div class="product-block" {{ block.shopify_attributes }}>
                      <div
                        class="aos-animate"
                        style="max-width: {{ block.settings.trust_image.width }}px; margin: 0 auto;"
                      >
                        <div
                          class="image-wrap "
                          style="height: 0; padding-bottom: {{ 100 | divided_by: block.settings.trust_image.aspect_ratio }}%;"
                        >
                          {%- render 'image-element',
                            img: block.settings.trust_image,
                            widths: '360, 540, 700, 1024',
                            sizeVariable: product_description_width
                          -%}
                        </div>
                      </div>
                    </div>
                  {%- when 'custom' -%}
                    <div class="product-block" {{ block.shopify_attributes }}>
                      {{ block.settings.code }}
                    </div>
                {%- endcase -%}

              {%- else -%}
                <div
                  data-blocks-holder
                  data-url="{{ product.url | within: collection }}"
                  data-template="{{ product.template_suffix }}"
                >
                  <div class="placeholder-content" style="min-height: 86px;"></div>
                </div>
              {%- endfor -%}
              {% unless product.handle contains 'gift-card' %}
                <div class="additional__tag_links medium-up--hide">
                  <h4>View More:</h4>
                  <ul>
                    {% assign pro_collection = product.collections.last %}
                    {% assign var = product.title | split: ' ' | first | handleize %}

                    {% if product_tags contains 'collection-' %}
                      {% for tag in product.tags %}
                        {% if tag contains 'collection-' %}
                          {% assign var = tag | replace: 'collection-', '' %}
                          {% assign var = var | replace: '-collection', '' %}
                        {% endif %}
                      {% endfor %}
                    {% endif %}

                    {% for col in product.collections %}
                      {% assign downcol = col.handle %}
                      {% comment %}<span class="collection-titletesttt {{ downcol }}=={{ var }}"></span>{% endcomment %}
                      {% if downcol contains var %}
                        {% assign parentcol = col %}
                      {% endif %}
                    {% endfor %}
                    {% if parentcol %}
                      <li>
                        <span class="collection-title v">
                          {{ parentcol.title | link_to: parentcol.url }}
                        </span>
                      </li>
                    {% else %}
                      <li>
                        <span class="collection-title {{ downcol }}-{{ var }}">
                          {{ pro_collection.title | link_to: pro_collection.url }}
                        </span>
                      </li>
                    {% endif %}

                    {% assign product_types = '' %}
                    {% for product in parentcol.products %}
                      {% unless product_types contains product.type %}
                        {% assign product_types = product_types | append: product.type | append: ',' %}
                      {% endunless %}
                    {% endfor %}
                    {% assign product_types_array = product_types | split: ',' %}

                    {% for type in product_types_array limit: 4 %}
                      {% assign type_handle = type | handleize %}
                      {% unless type == '' %}
                        <li class="{{ type }}">
                          <a href="{{ parentcol.url }}/{{ type_handle }}">
                            {% if type == 'Ring' %}
                              {{ type | pluralize: 'Ring', 'Rings' }}
                            {% elsif type == 'Pendant' %}
                              {{ type | pluralize: 'Pendant', 'Pendants' }}
                            {% elsif type == 'Necklace' %}
                              {{ type | pluralize: 'Necklace', 'Necklaces' }}
                            {% elsif type == 'Bracelet' %}
                              {{ type | pluralize: 'Bracelet', 'Bracelets' }}
                            {% else %}
                              {{ type }}
                            {% endif %}
                          </a>
                        </li>
                      {% endunless %}
                    {% endfor %}
                  </ul>
                </div>
              {% endunless %}
            </div>

            {%- unless product.empty? -%}
              <textarea class="hide" aria-hidden="true" aria-label="Product JSON" data-variant-json>
                {{ product.variants | json }}
              </textarea>
              {%- if product.options.size > 1 -%}
                <textarea class="hide" aria-hidden="true" aria-label="Variant JSON" data-current-variant-json>
                  {{ current_variant | json }}
                </textarea>
              {%- endif -%}
            {%- endunless -%}
          </div>
        </div>

        {%- unless image_position == 'left' -%}
          <div class="grid__item {{ product_image_width }} product-single__sticky">
            {%- render 'product-images',
              section_id: section_id,
              product: product,
              isModal: isModal,
              image_position: image_position,
              product_zoom_enable: product_zoom_enable,
              product_zoom_size: product_zoom_size,
              product_image_size: product_image_size,
              thumbnail_arrows: thumbnail_arrows,
              thumbnail_position: thumbnail_position,
              video_looping: video_looping,
              video_style: video_style,
              context: context,
              sizes: sizes,
              sizeVariable: product_image_width,
              fallback: fallback,
              mobile_layout: mobile_layout
            -%}
          </div>
        {%- endunless -%}
      </div>
    </div>
  </div>
</div>
<script>
  const productTagss = {{ product.tags | json }};
</script>
