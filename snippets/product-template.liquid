{% comment %}
  Parameters
  context - used to determine whether on the featured product or main product template
  mobile_layout
{% endcomment %}

{%- liquid
  assign current_variant = product.selected_or_first_available_variant

  unless thumbnail_position
    assign thumbnail_position = 'beside'
  endunless

  assign product_zoom_size = '1800x1800'
  assign product_image_size = '620x'

  case image_container_width
    when 'small'
      assign product_image_width = 'medium-up--two-fifths'
      assign product_description_width = 'medium-up--three-fifths'
      assign product_image_size = '480x'
    when 'medium'
      assign product_image_width = 'medium-up--one-half'
      assign product_description_width = 'medium-up--one-half'
      assign product_image_size = '620x'
    when 'large'
      assign product_image_width = 'medium-up--three-fifths'
      assign product_description_width = 'medium-up--two-fifths'
      assign product_image_size = '740x'
  endcase

  assign product_img_structure = product.featured_media | img_url: '1x1' | replace: '_1x1.', '_{width}x.'
-%}
{% assign product_tags = product.tags | join: ',' %}
{%- liquid
  assign connect_to_sizechart = true

  for block in section.blocks
    if block.type == 'size_chart'
      assign sizechart_index = forloop.index0
      assign next_block_index = sizechart_index | plus: 1
      assign variant_block = section.blocks[next_block_index]

      if variant_block.type == 'variant_picker' and variant_block.settings.picker_type == 'button' and product.has_only_default_variant == false
        for option in product.options_with_values
          assign size_trigger = 'products.general.size_trigger' | t | downcase
          assign downcased_option = option.name | downcase

          if downcased_option contains size_trigger
            assign connect_to_sizechart = true
          elsif downcased_option == 'length'
            assign connect_to_sizechart = true
          endif
        endfor
      endif
    endif
  endfor
-%}

<div
  id="ProductSection-{{ section_id }}-{{ product.id }}"
  class="product-section"
  data-section-id="{{ section_id }}"
  data-product-id="{{ product.id }}"
  data-section-type="product"
  data-product-handle="{{ product.handle }}"
  data-product-title="{{ product.title | escape }}"
  data-product-url="{{ product.url | within: collection }}"
  data-aspect-ratio="{{ 100 | divided_by: product.featured_media.aspect_ratio }}"
  data-img-url="{{ product_img_structure }}"
  {% unless isModal %}
    data-history="true"
  {% endunless %}
  data-modal="{{ isModal }}"
>
  {%- render 'product-template-variables', product: product, current_variant: current_variant -%}

  <div class="page-content page-content--product">
    <div class="ppage-width">
      <div class="grid{% unless image_position == 'left' %} grid--product-images-right{% endunless %}{% if mobile_layout == 'partial' %} grid--product-images--partial{% endif %}">
        {% if section.settings.showstickyfeaturedvid %}
          <div class="grid__item medium-up--one-third product-single__sticky small--hide">
            {% assign last_media = product.media | last %}
            {%- liquid
              case last_media.media_type
                when 'external_video'
                  assign has_video = true
                  assign video_type = last_media.host
                  assign video_id = last_media.external_id
                when 'video'
                  assign has_video = true
                  assign video_type = 'mp4'
              endcase
            -%}
            {% if last_media.media_type == 'image' %}
              <img
                src="{{ last_media | img_url: 'master' }}"
                alt="{{ last_media.alt }}"
                class="product-image"
                width=""
                height=""
              >
            {% elsif last_media.media_type == 'video' or last_media.media_type == 'external_video' %}
              {%- if video_type == 'youtube' -%}
                <a
                  href="https://youtube.com/watch?v={{ last_media.external_id }}"
                  class="btn btn--circle btn--large btn--static product-video-trigger"
                  data-video-id="{{ media.external_id }}"
                >
                  <svg
                    aria-hidden="true"
                    focusable="false"
                    role="presentation"
                    class="icon icon-play"
                    viewBox="18.24 17.35 24.52 28.3"
                  >
                    <path fill="#323232" d="M22.1 19.151v25.5l20.4-13.489-20.4-12.011z"/>
                  </svg>
                </a>
              {%- endif -%}
              {%- if video_type == 'vimeo' -%}
                <a
                  href="https://player.vimeo.com/video/{{ last_media.external_id }}"
                  class="btn btn--circle btn--large btn--static product-video-trigger"
                  data-video-id="{{ last_media.external_id }}"
                  data-video-loop="{{ video_looping }}"
                >
                  <svg
                    aria-hidden="true"
                    focusable="false"
                    role="presentation"
                    class="icon icon-play"
                    viewBox="18.24 17.35 24.52 28.3"
                  >
                    <path fill="#323232" d="M22.1 19.151v25.5l20.4-13.489-20.4-12.011z"/>
                  </svg>
                </a>
              {%- endif -%}
              {%- if video_type == 'mp4' -%}
                <video
                  playsinline
                  muted
                  autoplay
                  {% if video_looping %}
                    loop
                  {% endif %}
                  controls
                  controlsList="nodownload"
                  poster="{{ last_media.preview_image | img_url: product_image_size }}"
                  data-video-type="{{ video_type }}"
                  data-video-style="muted"
                  class="product-video-mp4-sound"
                >
                  {%- for source in last_media.sources -%}
                    <source src="{{ source.url }}" type="{{ source.mime_type }}">
                  {%- endfor -%}
                  Your browser does not support the video tag.
                </video>
              {%- endif -%}
            {% endif %}
          </div>
        {% endif %}

        {%- if image_position == 'left' -%}
          <div class="grid__item {% if section.settings.showstickyfeaturedvid %}medium-up--one-third {% else %} medium-up--two-thirds{% endif %}">
            {%- render 'product-images',
              section_id: section_id,
              product: product,
              isModal: isModal,
              image_position: image_position,
              product_zoom_enable: product_zoom_enable,
              product_zoom_size: product_zoom_size,
              product_image_size: product_image_size,
              thumbnail_arrows: thumbnail_arrows,
              thumbnail_height: thumbnail_height,
              thumbnail_position: thumbnail_position,
              video_looping: video_looping,
              video_style: video_style,
              context: context,
              sizes: sizes,
              sizeVariable: product_image_width,
              fallback: fallback,
              mobile_layout: mobile_layout
            -%}
            {% unless product.handle contains 'gift-card' %}
              <div class="page-width small--hide">
                <div class="additional__tag_links">
                  <h4>View More:</h4>
                  <ul>
                    {% assign pro_collection = product.collections.last %}
                    {% assign var = product.title | split: ' ' | first | handleize %}
                    {% if product_tags contains 'collection-' %}
                      {% for tag in product.tags %}
                        {% if tag contains 'collection-' %}
                          {% assign var = tag | replace: 'collection-', '' %}
                          {% assign var = var | replace: '-collection', '' %}
                        {% endif %}
                      {% endfor %}
                    {% endif %}
                    {% for col in product.collections %}
                      {% assign downcol = col.handle %}
                      {% comment %}<span class="collection-titletesttt {{ downcol }}=={{ var }}"></span>{% endcomment %}
                      {% if downcol contains var %}
                        {% assign parentcol = col %}
                      {% endif %}
                    {% endfor %}
                    {% if parentcol %}
                      <li>
                        <span class="collection-title v">
                          {{ parentcol.title | link_to: parentcol.url }}
                        </span>
                      </li>
                    {% else %}
                      <li>
                        <span class="collection-title {{ downcol }}-{{ var }}">
                          {{ pro_collection.title | link_to: pro_collection.url }}
                        </span>
                      </li>
                    {% endif %}

                    {% assign product_types = '' %}

                    {% for product in parentcol.products %}
                      {% unless product_types contains product.type %}
                        {% assign product_types = product_types | append: product.type | append: ',' %}
                      {% endunless %}
                    {% endfor %}
                    {% assign product_types_array = product_types | split: ',' %}
                    {% for type in product_types_array limit: 4 %}
                      {% assign type_handle = type | handleize %}
                      {% unless type == '' %}
                        <li class="{{ type }}">
                          <a href="{{ parentcol.url }}?filter.p.product_type={{ type }}">
                            {% if type == 'Ring' %}
                              {{ type | pluralize: 'Ring', 'Rings' }}
                            {% elsif type == 'Pendant' %}
                              {{ type | pluralize: 'Pendant', 'Pendants' }}
                            {% elsif type == 'Necklace' %}
                              {{ type | pluralize: 'Necklace', 'Necklaces' }}
                            {% elsif type == 'Bracelet' %}
                              {{ type | pluralize: 'Bracelet', 'Bracelets' }}
                            {% else %}
                              {{ type }}
                            {% endif %}
                          </a>
                        </li>
                      {% endunless %}
                    {% endfor %}
                  </ul>
                </div>
              </div>
            {% endunless %}
          </div>
        {%- endif -%}

        <div class="grid__item medium-up--one-third product-single__sticky">
          <div class="product-single__meta">
            <div class="product-block product-block--header">
              {%- if settings.show_breadcrumbs and isModal != true -%}
                {%- render 'breadcrumbs' -%}
              {%- endif -%}

              {%- if settings.vendor_enable -%}
                <div class="product-single__vendor">
                  {%- assign vendor_handle = product.vendor | handleize -%}
                  {%- if collections[vendor_handle] != empty -%}
                    <a href="{{ routes.collections_url }}/{{ collections[vendor_handle].handle }}">
                      {{ collections[vendor_handle].title }}
                    </a>
                  {%- else -%}
                    {{ product.vendor | link_to_vendor }}
                  {%- endif -%}
                </div>
              {%- endif -%}

              {% assign variable_product_metafields = product.metafields %}
              {% assign product_tags = product.tags | join: ',' %}
              {% assign has_custom_label = false %}

              {%- if isModal -%}
                <p class="h2 product-single__title product-single__title_withsubtitle">
                  {{ product.title }}
                </p>
              {%- else -%}
                <h1 class="h2 product-single__title product-single__title_withsubtitle">
                  <span>
                    {%- unless product.empty? -%}
                      {{ product.title }}
                    {%- else -%}
                      {{ 'home_page.onboarding.product_title' | t }}
                    {%- endunless -%}
                  </span>
                  <style>
                    #custom-wishlist-button.swym-added .swym-icon-unfilled {
                        display: none;
                    }
                    #custom-wishlist-button:not(.swym-added) .swym-icon-filled {
                        display: none;
                    }
                    #custom-wishlist-button {
                        background: unset !important;
                    }
                    .product-single__meta button.swym-button.swym-add-to-wishlist {
                        right: 0;
                        top: 0;opacity: 1!Important;
                    }
                  </style>
                  {% unless customer %}
                    <a href="#" id="custom-wishlist-button" class="custom-add-to-wishlist button">
                      <!-- Unfilled star -->
                      <svg class="swym-icon-unfilled" viewBox="0 0 24 24" height="24px" width="auto">
                        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" fill="none" stroke="currentColor" stroke-width="2"/>
                      </svg>
                      <!-- Filled star -->
                      <svg class="swym-icon-filled" viewBox="0 0 24 24" height="24px" width="auto">
                        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" fill="currentColor"/>
                      </svg>
                    </a>
                    <script>
                      function wishlistLoginCheckHandler() {
                        debugger;
                        const isLoggedIn = {% if customer %}true{% else %}false{% endif %};
                        const customBtn = document.querySelector(".custom-add-to-wishlist");
                        if (!customBtn) return;
                        customBtn.addEventListener("click", function(e) {
                          e.preventDefault();
                          if (isLoggedIn) {
                            let productData = { ...window.SwymPageData, et: _swat.EventTypes.addToWishList };
                            _swat.addToWishList(productData, () => console.log("Added to wishlist"));
                          } else {
                            window.location.href = "/account/login";
                          }
                        });
                      }
                      if (!window._swat) {
                        if (!window.SwymCallbacks) { window.SwymCallbacks = []; }
                        window.SwymCallbacks.push(wishlistLoginCheckHandler);
                      } else { wishlistLoginCheckHandler(); }
                    </script>
                  {% else %}
                    <button
                      id="custom-wishlist-button"
                      class="swym-button swym-add-to-wishlist"
                      data-with-epi="true"
                      data-swaction="addToWishlist"
                      data-product-id="{{ product.id }}"
                      data-variant-id="{{ product.variants[0].id }}"
                      data-product-url="{{ shop.url }}{{ product.url }}"
                    >
                      <!-- Unfilled star -->
                      <svg class="swym-icon-unfilled" viewBox="0 0 24 24" height="24px" width="auto">
                        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" fill="none" stroke="currentColor" stroke-width="2"/>
                      </svg>
                      <!-- Filled star -->
                      <svg class="swym-icon-filled" viewBox="0 0 24 24" height="24px" width="auto">
                        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" fill="currentColor"/>
                      </svg>
                    </button>
                  {% endunless %}
                  <small>{{ product.metafields.custom.subtitle }}</small>
                </h1>
              {%- endif -%}

              {%- if sku_enable -%}
                <p data-sku class="product-single__sku">
                  {%- if current_variant.sku -%}
                    {{ current_variant.sku }}
                  {%- endif -%}
                </p>
              {%- endif -%}

              {% if variable_product_metafields.theme.label and variable_product_metafields.theme.label != blank %}
                {% assign has_custom_label = true %}
                {% assign custom_label = variable_product_metafields.theme.label.value %}
              {% elsif product_tags contains '_label_' %}
                <div class="product__tagslist product__tags--custom">
                  {% for tag in product.tags %}
                    {% if tag contains '_label_' %}
                      {% assign tag_starts_with = tag | slice: 0 %}
                      {% if tag_starts_with == '_' %}
                        {% assign has_custom_label = true %}
                        {% assign custom_label = tag | replace: '_label_', '' %}
                      {% endif %}
                    {% endif %}
                  {% endfor %}
                  {%- if has_custom_label -%}
                    <div class="product__tag product__tag--custom">
                      {{ custom_label }}
                    </div>
                  {%- endif -%}
                </div>
              {% endif %}
            </div>

            <div data-product-blocks>
              {%- capture form_id -%}AddToCartForm-{{ section_id }}-{{ product.id }}{%- endcapture -%}
              {%- for block in blocks -%}
                {%- case block.type -%}
                  {%- when '@app' -%}
                    {% unless product_tags contains 'POA' %}
                      {% render block %}
                    {% endunless %}
                  {%- when 'separator' -%}
                    <div class="product-block" {{ block.shopify_attributes }}><hr></div>
                  {%- when 'text' -%}
                    <div class="product-block" {{ block.shopify_attributes }}>
                      {{ block.settings.text }}
                    </div>
                  {%- when 'popup' -%}
                    <div class="accord__popups">
                      {%- render 'tool-tip-trigger',
                        title: block.settings.title,
                        content: block.settings.content,
                        showarrows: true,
                        context: 'desc-popups'
                      -%}

                      {% if product.metafields.custom.enable_what_is_vermeil.value == true %}
                        {%- render 'tool-tip-trigger',
                          title: block.settings.title1,
                          content: block.settings.content1,
                          showarrows: true,
                          context: 'desc-popups'
                        -%}
                      {% endif %}

                      {% if product.metafields.custom.enable_lab_grown_diamonds.value == true %}
                        {%- render 'tool-tip-trigger',
                          title: block.settings.title4,
                          content: block.settings.content4,
                          showarrows: true,
                          context: 'desc-popups'
                        -%}
                      {% endif %}
                      {% if product.metafields.custom.enable_naturals_pearls.value == true %}
                        {%- render 'tool-tip-trigger',
                          title: block.settings.title5,
                          content: block.settings.content5,
                          showarrows: true,
                          context: 'desc-popups'
                        -%}
                      {% endif %}
                      {% if product.metafields.custom.enable_vegan_leather.value == true %}
                        {%- render 'tool-tip-trigger',
                          title: block.settings.title6,
                          content: block.settings.content6,
                          showarrows: true,
                          context: 'desc-popups'
                        -%}
                      {% endif %}

                      {%- render 'tool-tip-trigger',
                        title: block.settings.title2,
                        content: block.settings.content2,
                        showenquiry: true,
                        showarrows: true,
                        context: 'desc-popups'
                      -%}

                      {% if product.metafields.custom.enable_customize.value == true %}{% endif %}
                      {%- render 'tool-tip-trigger',
                        title: block.settings.title3,
                        content: block.settings.content3,
                        showarrows: true,
                        context: 'desc-popups'
                      -%}
                    </div>

                    {% unless product_tags contains 'POA' %}
                      <div class="prod_popups_all_links">
                        <h4>{{ section.settings.cus_title }}</h4>
                        <p>{{ section.settings.cus_text }}</p>
                        <button class="button globo-formbuilder-open underline" data-id="OTU4NzQ=">
                          {{ section.settings.button_text }}
                        </button>
                      </div>
                    {% endunless %}

                  {%- when 'vtab' -%}
                    <div id="tabmenu">
                      <ul id="nav" class="tabs">
                        {% if block.settings.tab1 != blank %}
                          <li>
                            <a href="#tab-1">{{ block.settings.tab1 }}</a>
                          </li>
                        {% endif %}
                        {% if block.settings.tab2 != blank and block.settings.content2 != blank %}
                          <li>
                            <a href="#tab-2">{{ block.settings.tab2 }}</a>
                          </li>
                        {% endif %}
                        {% if block.settings.tab3 != blank and block.settings.content3 != blank %}
                          <li>
                            <a href="#tab-3">{{ block.settings.tab3 }}</a>
                          </li>
                        {% endif %}
                      </ul>
                      {% if block.settings.tab2 != blank and block.settings.content2 != blank %}
                        <div class="content" id="tab-1">
                          {% if block.settings.content1 != blank %}
                            {{ block.settings.content1 | escape }}
                          {% elsif product.description != blank %}
                            {{ product.description }}
                            <br>
                            <p data-sku class="product-single__sku product_sku">SKU: {{ current_variant.sku }}</p>
                          {% endif %}
                        </div>
                      {% endif %}
                      {% if block.settings.tab2 != blank and block.settings.content2 != blank %}
                        <div class="content" id="tab-2">
                          {{ block.settings.content2 }}
                        </div>
                      {% endif %}
                      {% if block.settings.tab3 != blank and block.settings.content3 != blank %}
                        <div class="content" id="tab-3">
                          {{ block.settings.content3 }}
                        </div>
                      {% endif %}

                      {% comment %}
                        <ul id="nav">
                          {% if block.settings.tab1 != blank  %}<li><span class="active">{{ block.settings.tab1 }}</span></li>{%  endif %}
                          {% if block.settings.tab2 != blank and block.settings.content2 != blank %}<li><span>{{ block.settings.tab2 }}</span></li>{%  endif %}
                          {% if block.settings.tab3 != blank and block.settings.content3 != blank %}<li><span>{{ block.settings.tab3 }}</span></li>{%  endif %}
                        </ul>
                        <div id="tab-content">
                          {% if block.settings.tab1 != blank  %}
                            <div class="contentbnnn " id="tab1">
                            {% if block.settings.content1 != blank %}
                              {{ block.settings.content1 | escapes }}
                            {% elsif product.description!= blank %}
                              {{ product.description }}
                              <br/><p class="product_sku">SKU: {{ current_variant.sku }}</p>
                            {% endif %}
                            </div>
                          {%  endif %}
                          {% if block.settings.tab2 != blank and block.settings.content2 != blank %}<div class="content"  id="tab2">{{ block.settings.content2  }}</div>{%  endif %}
                          {% if block.settings.tab3 != blank and block.settings.content3 != blank %}<div class="content"  id="tab3">{{ block.settings.content3 }}</div>{%  endif %}
                        </div>
                      {% endcomment %}
                    </div>

                  {%- when 'mtab' -%}
                    <div class="accordion">
                      {% capture tab_content7 %}
                        {{ block.settings.content7 }}
                        {{ block.settings.page.content7 }}
                      {% endcapture %}
                      {% assign tab_id = block.settings.title7 | handle %}
                      {% unless tab_content7 == blank and block.settings.title7 == blank %}
                        <div class="accordion-item active">
                          <button class="accordion-header">
                            {{ block.settings.title7 }}
                            {%- render 'collapsible-icons' -%}
                          </button>
                          <div id="acc_descs" class="accordion-content acc_descs description">
                            {{ tab_content7 }}
                            <p data-sku class="product-single__sku product_sku">SKU: {{ current_variant.sku }}</p>
                          </div>
                        </div>
                      {% endunless %}

                      {% if product.metafields.custom.enable_what_is_vermeil.value == true %}
                        {% capture tab_content1 %}
                        {{ block.settings.content1 }}
                        {{ block.settings.page.content1 }}
                      {% endcapture %}
                        {% assign tab_id = block.settings.title1 | handle %}
                        {% unless tab_content1 == blank and block.settings.title1 == blank %}
                          <div class="accordion-item">
                            <button class="accordion-header">
                              {{ block.settings.title1 }}
                              {%- render 'collapsible-icons' -%}
                            </button>
                            <div class="accordion-content">{{ tab_content1 }}</div>
                          </div>
                        {% endunless %}
                      {% endif %}

                      {% capture tab_content2 %}
                        {{ block.settings.content2 }}
                        {{ block.settings.page.content2 }}
                      {% endcapture %}
                      {% assign tab_id = block.settings.title2 | handle %}
                      {% unless tab_content7 == blank and block.settings.title2 == blank %}
                        <div class="accordion-item">
                          <button class="accordion-header">
                            {{ block.settings.title2 }}
                            {%- render 'collapsible-icons' -%}
                          </button>
                          <div class="accordion-content">{{ tab_content2 }}</div>
                        </div>
                      {% endunless %}

                      {% if product.metafields.custom.enable_lab_grown_diamonds.value == true %}
                        {% capture tab_content4 %}
                        {{ block.settings.content4 }}
                        {{ block.settings.page.content4 }}
                      {% endcapture %}
                        {% assign tab_id = block.settings.title4 | handle %}
                        {% unless tab_content1 == blank and block.settings.title4 == blank %}
                          <div class="accordion-item">
                            <button class="accordion-header">
                              {{ block.settings.title4 }}
                              {%- render 'collapsible-icons' -%}
                            </button>
                            <div class="accordion-content">{{ tab_content4 }}</div>
                          </div>
                        {% endunless %}
                      {% endif %}

                      {% if product.metafields.custom.enable_naturals_pearls.value == true %}
                        {% capture tab_content5 %}
                        {{ block.settings.content5 }}
                        {{ block.settings.page.content5 }}
                      {% endcapture %}
                        {% assign tab_id = block.settings.title5 | handle %}
                        {% unless tab_content1 == blank and block.settings.title5 == blank %}
                          <div class="accordion-item">
                            <button class="accordion-header">
                              {{ block.settings.title5 }}
                              {%- render 'collapsible-icons' -%}
                            </button>
                            <div class="accordion-content">{{ tab_content5 }}</div>
                          </div>
                        {% endunless %}
                      {% endif %}

                      {% if product.metafields.custom.enable_vegan_leather.value == true %}
                        {% capture tab_content6 %}
                        {{ block.settings.content5 }}
                        {{ block.settings.page.content6 }}
                      {% endcapture %}
                        {% assign tab_id = block.settings.title6 | handle %}
                        {% unless tab_content1 == blank and block.settings.title6 == blank %}
                          <div class="accordion-item">
                            <button class="accordion-header">
                              {{ block.settings.title6 }}
                              {%- render 'collapsible-icons' -%}
                            </button>
                            <div class="accordion-content">{{ tab_content6 }}</div>
                          </div>
                        {% endunless %}
                      {% endif %}
                    </div>
                    {% unless product_tags contains 'POA' %}
                      <div class="prod_popups_all_links">
                        <h4>{{ section.settings.cus_title }}</h4>
                        <p>{{ section.settings.cus_text }}</p>
                        <button class="button globo-formbuilder-open" data-id="OTU4NzQ=">
                          {{ section.settings.button_text }}
