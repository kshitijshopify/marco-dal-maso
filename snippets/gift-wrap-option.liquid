  {%- assign gift_wrap_product = all_products['gift-wrap'] -%}
  {%- if gift_wrap_product and gift_wrap_product.variants.size > 0 -%}
    {%- assign gift_wrap_variant_id = gift_wrap_product.variants.first.id -%}

    {%- assign has_gift_wrap = false -%}
    {%- for item in cart.items -%}
      {%- if item.product.handle == 'gift-wrap' -%}
        {%- assign has_gift_wrap = true -%}
      {%- endif -%}
    {%- endfor -%}

    {%- assign gift_msg = cart.attributes['Gift message'] | default: '' -%}
    {% if gift_msg != blank %}
        {%- assign has_gift_msg = gift_msg -%}
    {% else %}
        {%- assign has_gift_msg = '' -%}
    {% endif %}

    <div class="gift-options-wrapper">
      <div class="gift-option-row" style="display: none;">
        <span class="gift-option-label">{{ settings.gift_title }}</span>
        <button
          type="button"
          class="gift-option-action js-toggle-gift-wrap {% if has_gift_wrap %}added{% endif %}"
          data-variant-id="{{ gift_wrap_variant_id }}"
          data-handle="gift-wrap"
        >
          {% if has_gift_wrap %}
            <span class="added-text">{{settings.gift_added}} <span class="checkmark">✓</span></span>
          {% else %}
            {{ settings.gift_add }}
          {% endif %}
        </button>
      </div>

      <div class="gift-option-row">
        <span class="gift-option-label">{{ settings.message_title }}</span>
        <button
          type="button"
          class="gift-option-action js-toggle-message {% if has_gift_msg != blank %}added{% endif %}"
          data-visible="{% if has_gift_msg != blank %}true{% else %}false{% endif %}"
        >
          {% if has_gift_msg != blank %}
            <span class="added-text">{{settings.gift_added}} <span class="checkmark">✓</span></span>
          {% else %}
            {{ settings.gift_add }}
          {% endif %}
        </button>
      </div>

      <div class="gift-message-drawer" {% unless has_gift_msg != blank %}style="display:none"{% endunless %}>
        <textarea id="gift-message-input" maxlength="240" placeholder="Write your message here">{{ gift_msg }}</textarea>
        <div class="gift-message-save-status"></div>
      </div>
    </div>

    <style>
      .gift-options-wrapper { margin-bottom: 1rem; clear: both; position: relative; margin-top: 1.2rem; }
      .gift-options-wrapper::before { position: absolute; left: -30px; right: 0; width: calc(100% + 60px); content: ""; background: #f5f5f5; height: 100%; z-index: -1; top: 0rem; }
      .gift-option-row { display: flex ; justify-content: space-between; align-items: center; padding: .8rem 0; position: relative; font-size: 16px; }
      .gift-option-label { color:#000; font-weight:500; }
      .gift-option-action {text-decoration: underline; background:none; border:none; color:#000; text-transform:uppercase; font-weight:600; font-size:.85rem; cursor:pointer; padding:0; letter-spacing:.04em; }
      .gift-option-action:hover { text-decoration:underline; }
      .gift-option-action.added { color:#666; cursor:pointer; }
      .gift-option-action.added .checkmark { color:#009a34; font-weight:700; }
      .gift-message-drawer {padding:0 0 1rem;}
      .gift-message-label { display:block; margin-bottom:.4rem; font-weight:500; font-size:.85rem; }
      .gift-message-drawer textarea { width:100%; border:1px solid #ddd; border-radius:4px; padding:.6rem; font-size:.9rem; min-height:80px; resize:vertical; }
      .gift-message-save-status { margin-top:.3rem; font-size:.8rem; color:#666; display:none; }
      .gift-option-row:first-child:before {
    position: absolute;
    left: -30px;
    right: 0;
    width: calc(100% + 60px);
    content: "";
    background: #8C8686;
    height: 1px;
    z-index: 1;
    bottom: 0;
}
    </style>
  {%- endif -%}
