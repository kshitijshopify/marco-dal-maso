  (function() {
    // Skip if URL contains /products/
    if (window.location.pathname.includes("/products/") || window.location.pathname.includes("newsletter-signup")) {
      return; // exit the script
    }

    let fired = false;

    // Helper: wrap klaviyo.isIdentified() in a Promise
    function checkKlaviyoIdentity(timeout = 3000, interval = 100) {
    return new Promise((resolve) => {
      const start = Date.now();

      (function poll() {
        if (typeof klaviyo !== "undefined" && typeof klaviyo.isIdentified === "function") {
          resolve(klaviyo.isIdentified());
        } else if (Date.now() - start >= timeout) {
          resolve(false); // assume not identified if Klaviyo didn't load in time
        } else {
          setTimeout(poll, interval);
        }
      })();
    });
  }

  // Main logic wrapped in identity check
  checkKlaviyoIdentity().then((isIdentified) => {
    if (isIdentified) {
      console.log("🛑 Skipping — visitor already identified in Klaviyo.");
      return;
    }

    function triggerAction() {
    if (fired) return;
    fired = true;

    if (typeof Shopify !== "undefined" && Shopify.locale) {
      if (Shopify.locale === "en") {
        console.log("🇬🇧 English action fired"); 
        window._klOnsite = window._klOnsite || [];
        window._klOnsite.push(['openForm', 'T56xG4']);
      } else if (Shopify.locale === "it") {
        console.log("🇮🇹 Italian action fired"); 
        window._klOnsite = window._klOnsite || [];
        window._klOnsite.push(['openForm', 'VzrGey']);
      }
    } else {
      console.log("🔥 Action fired (no locale detected)");
      // 👉 Fallback code here
    }
  }

  // Condition 1: 15 seconds timer
  setTimeout(triggerAction, 20000);

  // Condition 2: Scroll 30% down
  function onScroll() {
    const scrollTop = window.scrollY || document.documentElement.scrollTop;
    const docHeight = document.documentElement.scrollHeight - window.innerHeight;
    const scrolled = (scrollTop / docHeight) * 100;
    if (scrolled >= 30) {
      triggerAction();
      window.removeEventListener("scroll", onScroll);
    }
  }
  window.addEventListener("scroll", onScroll);

  // Condition 3: 2 page views
  /**
  let views = parseInt(localStorage.getItem("pageViews") || "0", 10);
  views++;
  localStorage.setItem("pageViews", views);
  if (views >= 2) {
    triggerAction();
  }
  **/

  });
})();

</script>
