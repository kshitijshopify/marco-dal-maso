    <script>
      (function () {
        const ua = navigator.userAgent.toLowerCase();

        const blocked = [
          'tencent',
          'wechat',
          'micromessenger',
          'qq',
          'tx',
          'cloud',
          'aws',
          'amazon',
          'headless',
          'phantom',
          'puppeteer',
          'playwright',
          'selenium',
          'crawler',
          'spider',
          'bot'
        ];

        const isBot =
          blocked.some(k => ua.includes(k)) ||
          navigator.webdriver === true ||
          window.callPhantom ||
          window._phantom ||
          window.__nightmare;

        if (isBot) {
          // Kill everything immediately
          document.documentElement.innerHTML = '';
          document.body && (document.body.innerHTML = '');

          // Stop analytics
          window.dataLayer = [];
          window.gtag = function(){};
          window.ga = function(){};
          window.ShopifyAnalytics = null;

          // Stop network abuse
          window.fetch = function () {
            return Promise.reject('Blocked');
          };
          XMLHttpRequest.prototype.open = function () {
            throw new Error('Blocked');
          };

          // Optional hard redirect
          // location.replace('about:blank');

          throw new Error('Tencent / AWS bot blocked');
        }
      })();
